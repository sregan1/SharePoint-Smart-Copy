<Window x:Class="SharePointSmartCopy.Dialogs.HistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Copy History"
        Width="980" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBgBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Source="pack://application:,,,/Resources/logo.png"
                   Height="70" VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock Grid.Column="2" Text="Copy History" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
        </Grid>

        <!-- Main area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Report list -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Previous runs" FontWeight="SemiBold"
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>

                <ListBox Grid.Row="2" x:Name="ReportList"
                         BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1" Background="White"
                         SelectionChanged="ReportList_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayDate}"
                                           FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding SourceUrl}" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                <TextBlock FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                           TextTrimming="CharacterEllipsis">
                                    <Run Text="→ "/>
                                    <Run Text="{Binding TargetUrl}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding Summary}" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Vertical divider -->
            <Rectangle Grid.Column="1" Width="1" Fill="{StaticResource BorderLightBrush}" HorizontalAlignment="Center"/>

            <!-- Detail panel -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" x:Name="DetailHeader"
                           Text="Select a run to view details"
                           FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>

                <!-- Summary cards for selected report -->
                <StackPanel Grid.Row="2" x:Name="SummaryCards"
                            Orientation="Horizontal" Visibility="Collapsed">
                    <Border Style="{StaticResource SummaryCard}" Padding="16,8" Margin="0,0,8,0" MinWidth="90"
                            Background="{StaticResource SuccessBgBrush}" BorderBrush="{StaticResource SuccessBrush}">
                        <StackPanel>
                            <TextBlock x:Name="SuccessCard" Text="0" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Succeeded" Foreground="{StaticResource SuccessBrush}" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryCard}" Padding="16,8" Margin="0,0,8,0" MinWidth="90"
                            Background="{StaticResource DangerBgBrush}" BorderBrush="{StaticResource DangerBrush}">
                        <StackPanel>
                            <TextBlock x:Name="FailedCard" Text="0" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Failed" Foreground="{StaticResource DangerBrush}" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryCard}" Padding="16,8" Margin="0" MinWidth="90"
                            Background="{StaticResource WarningBgBrush}" BorderBrush="{StaticResource WarningBrush}">
                        <StackPanel>
                            <TextBlock x:Name="SkippedCard" Text="0" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource WarningTextBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Skipped" Foreground="{StaticResource WarningTextBrush}" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Detail DataGrid -->
                <Border Grid.Row="4" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1">
                    <DataGrid x:Name="DetailGrid"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" Background="White"
                              AlternatingRowBackground="#FAFAFA" BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="File Name"   Binding="{Binding FileName}"   Width="200"/>
                            <DataGridTemplateColumn Header="Status" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StatusDisplay}" Margin="4,2"
                                                   Foreground="{Binding StatusColor}"
                                                   FontWeight="SemiBold" FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Source Path" Binding="{Binding SourcePath}" Width="220"/>
                            <DataGridTextColumn Header="Target Path" Binding="{Binding TargetPath}" Width="220"/>
                            <DataGridTextColumn Header="Versions"    Binding="{Binding VersionsCopied}" Width="65"/>
                            <DataGridTextColumn Header="Error"       Binding="{Binding ErrorMessage}"  Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" x:Name="DeleteButton" Content="Delete Run"
                    Style="{StaticResource DangerBtn}"
                    IsEnabled="False" Click="DeleteButton_Click"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="ExportButton" Content="Export CSV"
                        Style="{StaticResource SecondaryBtn}"
                        IsEnabled="False" Margin="0,0,10,0" Click="ExportButton_Click"/>
                <Button Content="Close" Style="{StaticResource SecondaryBtn}" Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
