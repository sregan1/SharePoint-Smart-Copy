<Window x:Class="SharePointSmartCopy.Dialogs.CompareDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SharePointSmartCopy.Converters"
        xmlns:models="clr-namespace:SharePointSmartCopy.Models"
        Title="Compare Source and Target"
        Width="1040" Height="720"
        MinWidth="820" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBgBrush}"
        ResizeMode="CanResize">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InvertBoolConverter x:Key="InvBool"/>
        <conv:NullToVisibilityConverter x:Key="NotNullToVis"/>

        <HierarchicalDataTemplate x:Key="CompareNodeTemplate"
                                  DataType="{x:Type models:SharePointNode}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2,2">
                <TextBlock Text="{Binding TypeIcon}" Style="{StaticResource GlyphIcon}"
                           Foreground="{DynamicResource AccentBrush}" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"/>
                <ProgressBar IsIndeterminate="True" Width="60" Height="4" Margin="8,0,0,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid Margin="20" TextElement.Foreground="{DynamicResource TextPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Compare Source and Target" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,4,0,0"
                       Text="Connect to any source and target location and generate a difference report — independent of copy history."/>
        </StackPanel>

        <!-- Main area: Source | Target -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- Source pane -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Source" Style="{StaticResource SectionHeader}"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBox x:Name="SourceUrlBox" Width="260"
                             Text="{Binding SourceUrl, UpdateSourceTrigger=PropertyChanged}"
                             Tag="https://contoso.sharepoint.com/sites/source"
                             Style="{StaticResource WatermarkTextBox}"/>
                    <Button x:Name="SourceConnectButton" Content="Connect" Style="{StaticResource PrimaryBtn}" Margin="8,0,0,0"
                            Click="SourceConnect_Click"
                            IsEnabled="{Binding IsConnectingSource, Converter={StaticResource InvBool}}"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Text="{Binding SourceStatus}" FontSize="12"
                           Margin="0,6,0,0" Foreground="{DynamicResource TextSecondaryBrush}"
                           Visibility="{Binding SourceStatus, Converter={StaticResource NotNullToVis}}"/>

                <Border Grid.Row="4" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1"
                        Background="{DynamicResource SurfaceBrush}" MinHeight="200">
                    <TreeView x:Name="SourceTreeView"
                              ItemsSource="{Binding SourceLibraries}"
                              ItemTemplate="{StaticResource CompareNodeTemplate}"
                              SelectedItemChanged="SourceTree_SelectedItemChanged"
                              VirtualizingPanel.IsVirtualizing="False"
                              ScrollViewer.CanContentScroll="False"
                              ScrollViewer.VerticalScrollBarVisibility="Visible"
                              Padding="4">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <EventSetter Event="Expanded" Handler="SourceTreeItem_Expanded"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Border>
            </Grid>

            <!-- Vertical divider -->
            <Rectangle Grid.Column="1" Width="1" Fill="{DynamicResource BorderLightBrush}" HorizontalAlignment="Center"/>

            <!-- Target pane -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Target" Style="{StaticResource SectionHeader}"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBox x:Name="TargetUrlBox" Width="260"
                             Text="{Binding TargetUrl, UpdateSourceTrigger=PropertyChanged}"
                             Tag="https://contoso.sharepoint.com/sites/target"
                             Style="{StaticResource WatermarkTextBox}"/>
                    <Button x:Name="TargetConnectButton" Content="Connect" Style="{StaticResource PrimaryBtn}" Margin="8,0,0,0"
                            Click="TargetConnect_Click"
                            IsEnabled="{Binding IsConnectingTarget, Converter={StaticResource InvBool}}"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Text="{Binding TargetStatus}" FontSize="12"
                           Margin="0,6,0,0" Foreground="{DynamicResource TextSecondaryBrush}"
                           Visibility="{Binding TargetStatus, Converter={StaticResource NotNullToVis}}"/>

                <Border Grid.Row="4" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1"
                        Background="{DynamicResource SurfaceBrush}" MinHeight="200">
                    <TreeView x:Name="TargetTreeView"
                              ItemsSource="{Binding TargetLibraries}"
                              ItemTemplate="{StaticResource CompareNodeTemplate}"
                              SelectedItemChanged="TargetTree_SelectedItemChanged"
                              VirtualizingPanel.IsVirtualizing="False"
                              ScrollViewer.CanContentScroll="False"
                              ScrollViewer.VerticalScrollBarVisibility="Visible"
                              Padding="4">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <EventSetter Event="Expanded" Handler="TargetTreeItem_Expanded"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Border>
            </Grid>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="CompareCancelButton" Content="Cancel" Style="{StaticResource DangerBtn}"
                        Visibility="Collapsed" Click="CompareCancelButton_Click"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="DeepVerifyCheckBox" VerticalAlignment="Center" FontSize="12"
                              Margin="0,0,14,0" Checked="DeepVerifyCheckBox_Changed" Unchecked="DeepVerifyCheckBox_Changed"
                              AutomationProperties.Name="Deep verify Office files">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Deep verify Office files" VerticalAlignment="Center"/>
                            <TextBlock Style="{StaticResource ToolTipIcon}">
                                <TextBlock.ToolTip>
                                    <ToolTip MaxWidth="280">
                                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                                   Text="Downloads both copies of each mismatched Office file and compares their internal content, ignoring the metadata parts SharePoint rewrites on upload (Document ID, custom properties, etc.). Slower — use when a hash or date difference needs to be proven real or harmless."/>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </StackPanel>
                    </CheckBox>
                    <Button x:Name="CompareButton" Content="Compare with Excel Report"
                            Style="{StaticResource PrimaryBtn}"
                            IsEnabled="False" Margin="0,0,10,0" Click="CompareButton_Click"/>
                    <Button Content="Close" Style="{StaticResource SecondaryBtn}" Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- Full-width row, own line below the buttons — wraps rather than truncates, same reasoning
                 as HistoryDialog's status line. -->
            <TextBlock Grid.Row="1" x:Name="CompareStatus" FontSize="12" Visibility="Collapsed"
                       Margin="0,6,0,0" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextTertiaryBrush}"/>
        </Grid>
    </Grid>
</Window>
