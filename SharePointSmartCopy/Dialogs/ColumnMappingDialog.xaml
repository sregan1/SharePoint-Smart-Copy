<Window x:Class="SharePointSmartCopy.Dialogs.ColumnMappingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SharePointSmartCopy.Converters"
        Title="Column Mappings"
        Width="720" Height="520"
        MinWidth="560" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="#F3F3F3"
        ResizeMode="CanResize">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="#8A8886" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Column Mappings" FontSize="18" FontWeight="SemiBold"
                   Foreground="#201F1E" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="12" Foreground="#605E5C" Margin="0,0,0,12"
                   Text="{Binding HeaderDescription}"/>

        <!-- Column list -->
        <Border Grid.Row="2" Background="White" BorderBrush="#EDEBE9" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Column header row -->
                <Border Grid.Row="0" Background="#F3F3F3" BorderBrush="#EDEBE9" BorderThickness="0,0,0,1" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Source Column" FontWeight="SemiBold" FontSize="12" Foreground="#605E5C"/>
                        <TextBlock Grid.Column="1" Text="Type" FontWeight="SemiBold" FontSize="12" Foreground="#605E5C"/>
                        <TextBlock Grid.Column="3" FontWeight="SemiBold" FontSize="12" Foreground="#605E5C"
                                   Text="{Binding TargetColumnHeader}"/>
                    </Grid>
                </Border>

                <!-- Mapping rows / empty state -->
                <Grid Grid.Row="1">
                    <!-- Empty state: shown when there are no source columns to map -->
                    <Border Padding="32"
                            Visibility="{Binding HasNoMappings, Converter={StaticResource BoolToVis}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="No mappable columns" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#797775" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#A19F9D"
                                       HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="420">
                                The source library has no custom columns of a supported type.
                                Supported types: Text, Note, Number, Boolean, Date, Choice, Multi-choice.
                                Lookup, User, and Managed Metadata columns are not supported.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Rows: shown when there are source columns -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasNoMappings, Converter={StaticResource InvBoolToVis}}">
                        <ItemsControl x:Name="MappingsList" ItemsSource="{Binding Mappings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F3F3F3" BorderThickness="0,0,0,1" Padding="12,8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Mapping.Status}" Value="Unmatched">
                                                        <Setter Property="Background" Value="#FFF9F0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Source column name -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StatusIcon}" FontSize="13" Margin="0,0,6,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Mapping.SourceColumn.DisplayName}" FontSize="13"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Type badge -->
                                            <TextBlock Grid.Column="1" Text="{Binding Mapping.SourceColumn.FieldType}"
                                                       FontSize="11" Foreground="#797775" VerticalAlignment="Center"/>

                                            <!-- Arrow -->
                                            <TextBlock Grid.Column="2" Text="→" FontSize="13" Foreground="#A19F9D"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                            <!-- Target column selector -->
                                            <ComboBox Grid.Column="3" FontSize="12" VerticalAlignment="Center"
                                                      ItemsSource="{Binding DataContext.TargetColumnOptions, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      DisplayMemberPath="DisplayLabel"
                                                      SelectedItem="{Binding SelectedTargetItem, Mode=TwoWay}"
                                                      Padding="6,4"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <!-- Status bar -->
        <TextBlock Grid.Row="3" x:Name="StatusBar" FontSize="12" Foreground="#605E5C" Margin="0,8,0,0"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Auto-match" Style="{StaticResource SecondaryBtn}" Click="AutoMatch_Click" Margin="0,0,8,0"/>
            <Button Content="Cancel" Style="{StaticResource SecondaryBtn}" Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="Save mappings" Style="{StaticResource PrimaryBtn}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
