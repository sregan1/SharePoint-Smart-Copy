<Window x:Class="SharePointSmartCopy.Dialogs.ColumnMappingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SharePointSmartCopy.Converters"
        Title="Column Mappings"
        Width="720" Height="520"
        MinWidth="560" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBgBrush}"
        ResizeMode="CanResize">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>
    </Window.Resources>

    <Grid Margin="20" TextElement.Foreground="{DynamicResource TextPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Column Mappings" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,12"
                   Text="{Binding HeaderDescription}"/>

        <!-- Column list -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Column header row -->
                <Border Grid.Row="0" Background="{DynamicResource WindowBgBrush}" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Source Column" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="Type" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"/>
                        <TextBlock Grid.Column="3" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                                   Text="{Binding TargetColumnHeader}"/>
                    </Grid>
                </Border>

                <!-- Mapping rows / empty state -->
                <Grid Grid.Row="1">
                    <!-- Empty state: shown when there are no source columns to map -->
                    <Border Padding="32"
                            Visibility="{Binding HasNoMappings, Converter={StaticResource BoolToVis}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="No mappable columns" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextPlaceholderBrush}"
                                       HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="420">
                                The source library has no custom columns of a supported type.
                                Supported types: Text, Note, Number, Boolean, Date, Choice, Multi-choice, Person, Managed Metadata.
                                Lookup columns are not supported.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Rows: shown when there are source columns -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasNoMappings, Converter={StaticResource InvBoolToVis}}">
                        <ItemsControl x:Name="MappingsList" ItemsSource="{Binding Mappings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource WindowBgBrush}" BorderThickness="0,0,0,1" Padding="12,8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Mapping.Status}" Value="Unmatched">
                                                        <Setter Property="Background" Value="{DynamicResource UnmatchedBgBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Source column name -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StatusIcon}" FontSize="13" Margin="0,0,6,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Mapping.SourceColumn.DisplayName}" FontSize="13"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Type badge -->
                                            <TextBlock Grid.Column="1" Text="{Binding Mapping.SourceColumn.FieldType}"
                                                       FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center"/>

                                            <!-- Arrow -->
                                            <TextBlock Grid.Column="2" Text="→" FontSize="13" Foreground="{DynamicResource TextPlaceholderBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                            <!-- Target column selector -->
                                            <ComboBox Grid.Column="3" FontSize="12" VerticalAlignment="Center"
                                                      ItemsSource="{Binding CompatibleOptions}"
                                                      DisplayMemberPath="DisplayLabel"
                                                      SelectedItem="{Binding SelectedTargetItem, Mode=TwoWay}"
                                                      Padding="6,4"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <!-- Status bar -->
        <TextBlock Grid.Row="3" x:Name="StatusBar" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,8,0,0"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Auto-match" Style="{StaticResource SecondaryBtn}" Click="AutoMatch_Click" Margin="0,0,8,0"/>
            <Button Content="Cancel" Style="{StaticResource SecondaryBtn}" Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="Save mappings" Style="{StaticResource PrimaryBtn}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
