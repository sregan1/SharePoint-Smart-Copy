<Window x:Class="SharePointSmartCopy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SharePointSmartCopy.Converters"
        xmlns:vm="clr-namespace:SharePointSmartCopy.ViewModels"
        xmlns:models="clr-namespace:SharePointSmartCopy.Models"
        Title="SharePoint Smart Copy"
        Width="960" Height="720"
        MinWidth="800" MinHeight="600"
        Background="{StaticResource WindowBgBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>
        <conv:EqualToVisibilityConverter x:Key="EqToVis"/>
        <conv:NotEqualToVisibilityConverter x:Key="NeqToVis"/>
        <conv:CopyStatusToColorConverter x:Key="StatusColor"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis" Invert="True"/>
        <conv:NullToVisibilityConverter x:Key="NotNullToVis"/>
        <conv:IntToVisibilityConverter x:Key="IntToVis"/>
        <conv:InvertBoolConverter x:Key="InvBool"/>
        <conv:MultiEqualToBoolConverter x:Key="MultiEqual"/>

        <!-- ── Wizard step definitions ── -->
        <x:Array x:Key="WizardSteps" Type="models:StepInfo">
            <models:StepInfo Index="0" Display="1" Label="Source"/>
            <models:StepInfo Index="1" Display="2" Label="Browse"/>
            <models:StepInfo Index="2" Display="3" Label="Target"/>
            <models:StepInfo Index="3" Display="4" Label="Options"/>
            <models:StepInfo Index="4" Display="5" Label="Copy"/>
            <models:StepInfo Index="5" Display="✓" Label="Report" IsFinal="True"/>
        </x:Array>

        <!-- Bubble for one wizard step: gray when inactive, accent when current,
             green for the final (Report) step. DataContext is a StepInfo. -->
        <Style x:Key="StepBubble" TargetType="Border">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource BorderLightBrush}"/>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource MultiEqual}">
                            <Binding Path="DataContext.CurrentStep" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            <Binding Path="Index"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Value="True">
                            <Condition.Binding>
                                <MultiBinding Converter="{StaticResource MultiEqual}">
                                    <Binding Path="DataContext.CurrentStep" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    <Binding Path="Index"/>
                                </MultiBinding>
                            </Condition.Binding>
                        </Condition>
                        <Condition Binding="{Binding IsFinal}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StepBubbleText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource MultiEqual}">
                            <Binding Path="DataContext.CurrentStep" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            <Binding Path="Index"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ── Mode tile: Border whose Tag carries the scope's Is*Scope binding ── -->
        <Style x:Key="ModeTile" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="120"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModeTileGlyph" TargetType="TextBlock" BasedOn="{StaticResource GlyphIcon}">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModeTileTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModeTileDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource TileSelectedTextBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <!-- CheckBox that shows indeterminate (null) as a plain empty box — no black fill -->
        <Style x:Key="ItemsOnlyCheckBox" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent" SnapsToDevicePixels="True">
                            <BulletDecorator.Bullet>
                                <Border x:Name="Box" Width="14" Height="14" CornerRadius="2"
                                        BorderBrush="#767676" BorderThickness="1" Background="White">
                                    <Path x:Name="Check" Visibility="Collapsed"
                                          Stroke="{StaticResource AccentBrush}" StrokeThickness="1.8" StrokeLineJoin="Round"
                                          Data="M2,7 L5.5,10.5 L12,3.5"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <HierarchicalDataTemplate x:Key="SourceNodeTemplate"
                                  DataType="{x:Type models:SharePointNode}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2,2">
                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                          Style="{StaticResource ItemsOnlyCheckBox}"
                          IsThreeState="True"
                          Checked="SourceNode_CheckChanged"
                          Unchecked="SourceNode_CheckChanged"
                          Indeterminate="SourceNode_CheckChanged"
                          PreviewMouseLeftButtonDown="SourceCheckBox_PreviewClick"
                          VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding TypeIcon}" Style="{StaticResource GlyphIcon}"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"/>
                <TextBlock Text="{Binding SizeDisplay}" Foreground="{StaticResource TextTertiaryBrush}" FontSize="11"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                <ProgressBar IsIndeterminate="True" Width="60" Height="4" Margin="8,0,0,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <HierarchicalDataTemplate x:Key="TargetNodeTemplate"
                                  DataType="{x:Type models:SharePointNode}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2,2">
                <TextBlock Text="{Binding TypeIcon}" Style="{StaticResource GlyphIcon}"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"/>
                <ProgressBar IsIndeterminate="True" Width="60" Height="4" Margin="8,0,0,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <!-- ══ App Bar ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource AccentBrush}">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="6" Background="White" Padding="3"
                            VerticalAlignment="Center" Margin="0,0,10,0">
                        <Image RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Source>
                                <CroppedBitmap Source="pack://application:,,,/Resources/logo.png"
                                               SourceRect="0,0,625,415"/>
                            </Image.Source>
                        </Image>
                    </Border>
                    <TextBlock Text="SharePoint Smart Copy" FontSize="16" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SignedInUser}" Foreground="White" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,12,0"
                               Visibility="{Binding SignedInUser, Converter={StaticResource NotNullToVis}}"/>
                    <Button Style="{StaticResource AppBarBtn}" Margin="0,0,8,0" Click="HistoryButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE81C;" Style="{StaticResource GlyphIcon}" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="History" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource AppBarBtn}" Click="SettingsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" Style="{StaticResource GlyphIcon}" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Step Indicator ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderLightBrush}"
                BorderThickness="0,0,0,1" Padding="20,12">
            <ItemsControl ItemsSource="{StaticResource WizardSteps}" HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:StepInfo}">
                        <StackPanel Orientation="Horizontal">
                            <Border Height="2" Width="40" Background="{StaticResource BorderLightBrush}"
                                    VerticalAlignment="Top" Margin="4,13,4,0"
                                    Visibility="{Binding Index, Converter={StaticResource IntToVis}}"/>
                            <StackPanel>
                                <Border Style="{StaticResource StepBubble}">
                                    <TextBlock Text="{Binding Display}" Style="{StaticResource StepBubbleText}"/>
                                </Border>
                                <TextBlock Text="{Binding Label}" Style="{StaticResource StepText}"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- ══ Content Area ═════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="32,24">

            <!-- ── Step 0: Source URL ─────────────────────────────────────── -->
            <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=0}"
                        MaxWidth="520" HorizontalAlignment="Left">

                <TextBlock Text="Connect to Source Site" Style="{StaticResource SectionHeader}"/>
                <TextBlock Style="{StaticResource SubHeader}">
                    Enter the URL of the SharePoint site collection you want to copy <Run FontStyle="Italic">from</Run>.
                </TextBlock>

                <TextBlock Text="Source Site URL" Style="{StaticResource FieldLabel}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding SourceUrl, UpdateSourceTrigger=PropertyChanged}"
                             Tag="https://contoso.sharepoint.com/sites/source"
                             Style="{StaticResource WatermarkTextBox}"/>
                    <Grid Grid.Column="2">
                        <Button Content="Connect" Style="{StaticResource PrimaryBtn}"
                                Command="{Binding ConnectSourceCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                                Visibility="{Binding IsConnectingSource, Converter={StaticResource InvBoolToVis}}"/>
                        <Button Content="Disconnect" Style="{StaticResource DangerBtn}"
                                Command="{Binding CancelConnectSourceCommand}"
                                Visibility="{Binding IsConnectingSource, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                            Visibility="{Binding SourceStatus, Converter={StaticResource NotNullToVis}}">
                    <TextBlock Text="{Binding SourceStatus}" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text=" · " Foreground="{StaticResource TextPlaceholderBrush}" FontSize="13" VerticalAlignment="Center"
                               Visibility="{Binding SourceConnected, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="Disconnect" Style="{StaticResource LinkBtn}"
                            Command="{Binding DisconnectSourceCommand}"
                            Foreground="{StaticResource TextTertiaryBrush}" FontSize="13" Padding="0" VerticalAlignment="Center"
                            Visibility="{Binding SourceConnected, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <Border Style="{StaticResource InfoBanner}" Padding="14,10" Margin="0,20,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="&#xEA80;" Style="{StaticResource GlyphIcon}"
                                       Foreground="{StaticResource AccentBrush}" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="Requirements" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="20">
                            <Run>• You must have read access to the source site collection.</Run>
                            <LineBreak/>
                            <Run>• Configure your Azure AD app ID in Settings before connecting.</Run>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,16,0,0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <!-- ── Step 1: Browse Source ──────────────────────────────────── -->
            <Grid Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=1}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="What would you like to copy?" Style="{StaticResource SectionHeader}"/>

                <!-- ── Mode tile selector ── -->
                <UniformGrid Grid.Row="1" Columns="4" Margin="0,8,0,12">
                    <Border Style="{StaticResource ModeTile}" Tag="{Binding IsFilesScope}"
                            MouseLeftButtonUp="ModeFiles_Click">
                        <StackPanel>
                            <TextBlock Text="&#xE7C3;" Style="{StaticResource ModeTileGlyph}"/>
                            <TextBlock Text="Files &amp; Folders" Style="{StaticResource ModeTileTitle}"/>
                            <TextBlock Text="Copy individual files between libraries" Style="{StaticResource ModeTileDesc}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ModeTile}" Tag="{Binding IsLibraryScope}"
                            MouseLeftButtonUp="ModeLibrary_Click">
                        <StackPanel>
                            <TextBlock Text="&#xE8F1;" Style="{StaticResource ModeTileGlyph}"/>
                            <TextBlock Text="Libraries &amp; Lists" Style="{StaticResource ModeTileTitle}"/>
                            <TextBlock Text="Recreate libraries &amp; lists with structure and columns" Style="{StaticResource ModeTileDesc}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ModeTile}" Tag="{Binding IsSiteScope}"
                            MouseLeftButtonUp="ModeSite_Click">
                        <StackPanel>
                            <TextBlock Text="&#xE774;" Style="{StaticResource ModeTileGlyph}"/>
                            <TextBlock Text="Entire Site" Style="{StaticResource ModeTileTitle}"/>
                            <TextBlock Text="Copy all libraries from the source site" Style="{StaticResource ModeTileDesc}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ModeTile}" Tag="{Binding IsPagesScope}" Margin="0"
                            MouseLeftButtonUp="ModePages_Click">
                        <StackPanel>
                            <TextBlock Text="&#xE8A1;" Style="{StaticResource ModeTileGlyph}"/>
                            <TextBlock Text="Site Pages" Style="{StaticResource ModeTileTitle}"/>
                            <TextBlock Text="Copy modern pages with web parts" Style="{StaticResource ModeTileDesc}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Grid.Row="2" Style="{StaticResource InfoBanner}" Padding="10,6" Margin="0,0,0,8">
                    <TextBlock FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis">
                        <Run Text="Source: " FontWeight="SemiBold"/>
                        <Run Text="{Binding SourceUrl}"/>
                    </TextBlock>
                </Border>

                <!-- Scope-specific subheader -->
                <TextBlock Grid.Row="3" Style="{StaticResource SubHeader}"
                           Visibility="{Binding IsFilesScope, Converter={StaticResource BoolToVis}}">
                    Expand libraries and check the files or folders you want to copy.
                </TextBlock>
                <TextBlock Grid.Row="3" Style="{StaticResource SubHeader}"
                           Visibility="{Binding IsLibraryScope, Converter={StaticResource BoolToVis}}">
                    Check the libraries and lists you want to recreate at the target site.
                </TextBlock>
                <TextBlock Grid.Row="3" Style="{StaticResource SubHeader}"
                           Visibility="{Binding IsPagesScope, Converter={StaticResource BoolToVis}}">
                    Check the pages you want to copy. Use Select All to copy the entire Site Pages library.
                </TextBlock>
                <TextBlock Grid.Row="3" Style="{StaticResource SubHeader}"
                           Visibility="{Binding IsSiteScope, Converter={StaticResource BoolToVis}}">
                    All libraries from the source site will be copied. Connect the target to continue.
                </TextBlock>

                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,8"
                            Visibility="{Binding IsSiteScope, Converter={StaticResource InvBoolToVis}}">
                    <Button Content="Select All" Style="{StaticResource LinkBtn}" Click="SelectAll_Click"/>
                    <TextBlock Text=" | " Foreground="{StaticResource BorderLightBrush}" VerticalAlignment="Center"/>
                    <Button Content="Deselect All" Style="{StaticResource LinkBtn}" Click="DeselectAll_Click"/>
                    <ProgressBar IsIndeterminate="True" Width="80" Height="4" Margin="16,0,0,0" VerticalAlignment="Center"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextTertiaryBrush}" FontSize="12"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <Border Grid.Row="5" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                        Background="White" MinHeight="200"
                        Visibility="{Binding IsSiteScope, Converter={StaticResource InvBoolToVis}}">
                    <TreeView x:Name="SourceTreeView"
                              ItemsSource="{Binding SourceLibraries}"
                              ItemTemplate="{StaticResource SourceNodeTemplate}"
                              Padding="4">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <EventSetter Event="Expanded" Handler="SourceTreeItem_Expanded"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Border>
            </Grid>

            <!-- ── Step 2: Target URL + Folder ───────────────────────────── -->
            <Grid Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=2}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Connect to Target Site" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Style="{StaticResource SubHeader}">
                        Enter the URL of the destination site collection.
                    </TextBlock>

                    <TextBlock Text="Target Site URL" Style="{StaticResource FieldLabel}" Margin="0,22,0,4"/>
                    <TextBox Text="{Binding TargetUrl, UpdateSourceTrigger=PropertyChanged}"
                             Tag="https://contoso.sharepoint.com/sites/target"
                             Style="{StaticResource WatermarkTextBox}"
                             Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Connect to Target" Style="{StaticResource PrimaryBtn}"
                                Command="{Binding ConnectTargetCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                                Visibility="{Binding IsConnectingTarget, Converter={StaticResource InvBoolToVis}}"/>
                        <Button Content="Disconnect" Style="{StaticResource DangerBtn}"
                                Command="{Binding CancelConnectTargetCommand}"
                                Visibility="{Binding IsConnectingTarget, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                Visibility="{Binding TargetStatus, Converter={StaticResource NotNullToVis}}">
                        <TextBlock Text="{Binding TargetStatus}" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text=" · " Foreground="{StaticResource TextPlaceholderBrush}" FontSize="13" VerticalAlignment="Center"
                                   Visibility="{Binding TargetConnected, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Disconnect" Style="{StaticResource LinkBtn}"
                                Command="{Binding DisconnectTargetCommand}"
                                Foreground="{StaticResource TextTertiaryBrush}" FontSize="13" Padding="0" VerticalAlignment="Center"
                                Visibility="{Binding TargetConnected, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <ProgressBar IsIndeterminate="True" Height="4" Margin="0,12,0,0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

                    <Border Style="{StaticResource WarningBanner}" Margin="0,20,0,0"
                            Visibility="{Binding NeedsTargetFolder, Converter={StaticResource BoolToVis}}">
                        <TextBlock TextWrapping="Wrap" FontSize="12">
                            Select the destination folder in the tree on the right.
                            Files will be copied into that folder.
                        </TextBlock>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Select Destination Folder" Style="{StaticResource SectionHeader}"
                               Visibility="{Binding NeedsTargetFolder, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="Target Site" Style="{StaticResource SectionHeader}"
                               Visibility="{Binding NeedsTargetFolder, Converter={StaticResource InvBoolToVis}}"/>

                    <!-- Folder picker (Files / Pages scope) -->
                    <StackPanel Visibility="{Binding NeedsTargetFolder, Converter={StaticResource BoolToVis}}">
                        <TextBlock Style="{StaticResource SubHeader}"
                                   Visibility="{Binding IsFilesScope, Converter={StaticResource BoolToVis}}">
                            Click a library or folder to select it as the copy destination.
                        </TextBlock>
                        <TextBlock Style="{StaticResource SubHeader}"
                                   Visibility="{Binding IsPagesScope, Converter={StaticResource BoolToVis}}">
                            The Site Pages library has been automatically selected as the destination.
                            Pages can only be copied into a Site Pages library.
                        </TextBlock>

                        <Border Padding="10,6" Margin="0,0,0,8">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource InfoBanner}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTargetFolder}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Hidden"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="13">
                                <Run FontFamily="{StaticResource GlyphFont}" Text="&#xE8B7;"/>
                                <Run Text=" Selected: "/>
                                <Run Text="{Binding SelectedTargetFolder.Name}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </Border>

                        <Border BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1" Background="White" MinHeight="300">
                            <TreeView x:Name="TargetTreeView"
                                      ItemsSource="{Binding TargetLibraries}"
                                      ItemTemplate="{StaticResource TargetNodeTemplate}"
                                      SelectedItemChanged="TargetTree_SelectedItemChanged"
                                      Padding="4">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        <EventSetter Event="Expanded" Handler="TargetTreeItem_Expanded"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>
                        </Border>
                    </StackPanel>

                    <!-- Library / Site scope: no folder picker needed -->
                    <StackPanel Visibility="{Binding NeedsTargetFolder, Converter={StaticResource InvBoolToVis}}">
                        <TextBlock Style="{StaticResource SubHeader}">
                            Libraries and lists will be created at the root of the target site. No folder selection is needed.
                        </TextBlock>
                        <Border Style="{StaticResource InfoBanner}" Padding="14,12" Margin="0,16,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#xE946;" Style="{StaticResource GlyphIcon}"
                                               Foreground="{StaticResource AccentBrush}" FontSize="13" Margin="0,0,6,0"/>
                                    <TextBlock Text="Library / List Creation" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                    Libraries and lists will be created at the root of the target site, preserving column schema and versioning settings. If a library or list already exists, any missing source columns will be added to it.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SuccessBanner}" Padding="10,6" Margin="0,12,0,0"
                                Visibility="{Binding TargetConnected, Converter={StaticResource BoolToVis}}">
                            <TextBlock FontSize="12">
                                <Run FontFamily="{StaticResource GlyphFont}" Text="&#xE73E;" Foreground="{StaticResource SuccessBrush}"/>
                                <Run Text=" Target: " FontWeight="SemiBold"/>
                                <Run Text="{Binding TargetUrl}"/>
                            </TextBlock>
                        </Border>

                        <!-- Destination list picker — only when individual items are selected -->
                        <StackPanel Visibility="{Binding IsItemSelectionActive, Converter={StaticResource BoolToVis}}"
                                    Margin="0,16,0,0">
                            <TextBlock Text="Destination List" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding TargetCustomLists}"
                                      SelectedItem="{Binding SelectedTargetList}"
                                      DisplayMemberPath="Title"
                                      Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource WatermarkTextBox}"
                                     Tag="Enter the name of the new list to create"
                                     Text="{Binding NewListName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,6"
                                     Visibility="{Binding IsCreatingNewList, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}">
                                Select the list on the target site where the selected items will be copied.
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ── Step 3: Options + Review ───────────────────────────────── -->
            <Grid Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=3}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                  <StackPanel>
                    <TextBlock Text="Copy Options" Style="{StaticResource SectionHeader}"/>

                    <!-- ── Library / Site options ──────────────────────────────── -->
                    <Border Style="{StaticResource Card}" Margin="0,8,0,0"
                            Visibility="{Binding IsLibraryOrSiteScope, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Library / List Options" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>
                            <CheckBox Content="Copy library content (files)"
                                      IsChecked="{Binding CopyLibraryContent}"
                                      Margin="0,0,0,4" FontSize="13"/>
                            <TextBlock Text="When off, only the column schema and library settings are recreated — no files are copied."
                                       Style="{StaticResource OptionCaption}" Margin="20,0,0,10"/>
                            <!-- File copy options shown when content copy is enabled -->
                            <StackPanel Visibility="{Binding CopyLibraryContent, Converter={StaticResource BoolToVis}}"
                                        Margin="0,6,0,0">
                                <CheckBox Content="Overwrite existing files"
                                          IsChecked="{Binding OverwriteFiles}"
                                          Margin="0,0,0,8" FontSize="13"/>
                                <CheckBox IsChecked="{Binding CopyVersions}" Margin="0,0,0,8" FontSize="13"
                                          AutomationProperties.Name="Copy version history">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Copy version history" VerticalAlignment="Center"/>
                                        <TextBlock Style="{StaticResource ToolTipIcon}">
                                            <TextBlock.ToolTip>
                                                <ToolTip MaxWidth="280">
                                                    <TextBlock TextWrapping="Wrap" FontSize="12"
                                                               Text="Copies file version history. Versions are uploaded oldest-first so history builds naturally."/>
                                                </ToolTip>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                                <StackPanel Visibility="{Binding CopyVersions, Converter={StaticResource BoolToVis}}"
                                            Margin="20,0,0,8">
                                    <CheckBox Content="Copy all versions"
                                              IsChecked="{Binding CopyAllVersions}"
                                              FontSize="12" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="IsEnabled" Value="True"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CopyAllVersions}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Latest " FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding MaxVersions, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="52" FontSize="12" Padding="6,4" VerticalAlignment="Center"/>
                                        <TextBlock Text=" versions" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                <!-- ── Site-scope only: Navigation ─── -->
                                <StackPanel Visibility="{Binding IsSiteScope, Converter={StaticResource BoolToVis}}"
                                            Margin="0,4,0,0">
                                    <Separator Margin="0,0,0,10" Background="{StaticResource BorderLightBrush}"/>
                                    <TextBlock Text="Site-level Options" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                    <CheckBox Content="Copy navigation (Quick Launch &amp; top bar)"
                                              IsChecked="{Binding CopyNavigation}"
                                              Margin="0,0,0,4" FontSize="13"/>
                                    <TextBlock Text="Replaces target navigation with source links. URLs are remapped to the target site."
                                               Style="{StaticResource OptionCaption}" Margin="20,0,0,0"/>
                                </StackPanel>
                                <!-- ── Permissions (Library &amp; Site scope) ─── -->
                                <Separator Margin="0,8,0,8" Background="{StaticResource BorderLightBrush}"/>
                                <CheckBox Content="Copy permissions"
                                          IsChecked="{Binding CopyPermissions, Mode=TwoWay}"
                                          Margin="0,0,0,4" FontSize="13"/>
                                <TextBlock Text="Copies unique role assignments for libraries, lists, folders, files, and items. Works best for same-tenant copies."
                                           Style="{StaticResource OptionCaption}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── Pages-specific options ───────────────────────────────── -->
                    <Border Style="{StaticResource Card}" Margin="0,8,0,0"
                            Visibility="{Binding IsPagesScope, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Page Options" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>
                            <CheckBox Content="Overwrite existing pages"
                                      IsChecked="{Binding OverwriteFiles}"
                                      Margin="0,0,0,8" FontSize="13"/>
                            <CheckBox Content="Remap web part URLs to target site"
                                      IsChecked="{Binding RemapPageWebPartUrls}"
                                      Margin="0,0,0,4" FontSize="13"/>
                            <TextBlock Style="{StaticResource OptionCaption}" Margin="20,0,0,0">
                                Replaces source site URLs in web part JSON. Web parts referencing
                                specific list IDs may still need manual review after copy.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- ── Files-scope options (Overwrite, Versions) ── -->
                    <Border Style="{StaticResource Card}" Margin="0,8,0,0"
                            Visibility="{Binding IsFilesScope, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <CheckBox Content="Overwrite existing files"
                                      IsChecked="{Binding OverwriteFiles}"
                                      Margin="0,0,0,8" FontSize="13"/>

                            <CheckBox IsChecked="{Binding CopyVersions}" Margin="0,0,0,8" FontSize="13"
                                      AutomationProperties.Name="Copy versions">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Copy versions" VerticalAlignment="Center"/>
                                    <TextBlock Style="{StaticResource ToolTipIcon}">
                                        <TextBlock.ToolTip>
                                            <ToolTip MaxWidth="280">
                                                <TextBlock TextWrapping="Wrap" FontSize="12"
                                                           Text="Copies file version history. Versions are uploaded oldest-first so history builds naturally."/>
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                </StackPanel>
                            </CheckBox>

                            <StackPanel Visibility="{Binding CopyVersions, Converter={StaticResource BoolToVis}}"
                                        Margin="20,0,0,8">
                                <CheckBox Content="Copy all versions"
                                          IsChecked="{Binding CopyAllVersions}"
                                          FontSize="12" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="IsEnabled" Value="True"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CopyAllVersions}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="Latest " FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding MaxVersions, UpdateSourceTrigger=PropertyChanged}"
                                             Width="52" FontSize="12" Padding="6,4" VerticalAlignment="Center"/>
                                    <TextBlock Text=" versions" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <Separator Margin="0,4,0,8" Background="{StaticResource BorderLightBrush}"/>
                            <CheckBox Content="Copy permissions"
                                      IsChecked="{Binding CopyPermissions, Mode=TwoWay}"
                                      Margin="0,0,0,4" FontSize="13"/>
                            <TextBlock Text="Copies unique role assignments for files. Works best for same-tenant copies."
                                       Style="{StaticResource OptionCaption}" Margin="20,0,0,0"/>

                        </StackPanel>
                    </Border>

                    <!-- ── Metadata Options (all scopes) ───────────────────────── -->
                    <Border Style="{StaticResource Card}" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="Metadata" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>

                            <CheckBox IsChecked="{Binding PreserveMetadata}" Margin="0,0,0,4" FontSize="13">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Preserve metadata" VerticalAlignment="Center"/>
                                    <TextBlock Style="{StaticResource ToolTipIcon}">
                                        <TextBlock.ToolTip>
                                            <ToolTip MaxWidth="280">
                                                <TextBlock TextWrapping="Wrap" FontSize="12"
                                                           Text="Preserves Created By, Created Date, Modified By, and Modified Date on every copied item. When off, items appear as created by you today."/>
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                </StackPanel>
                            </CheckBox>
                            <TextBlock Text="Dates and author fields from the source are written to the target."
                                       Style="{StaticResource OptionCaption}" Margin="20,0,0,10"/>

                            <!-- Files scope: opt-in checkbox + mapping button -->
                            <StackPanel Visibility="{Binding IsFilesScope, Converter={StaticResource BoolToVis}}">
                                <CheckBox IsChecked="{Binding CopyCustomColumns}" Margin="0,0,0,4" FontSize="13"
                                          x:Name="CopyCustomColumnsCheckBox" Checked="CopyCustomColumns_Changed" Unchecked="CopyCustomColumns_Changed">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Copy custom column values" VerticalAlignment="Center"/>
                                        <TextBlock Style="{StaticResource ToolTipIcon}">
                                            <TextBlock.ToolTip>
                                                <ToolTip MaxWidth="280">
                                                    <TextBlock TextWrapping="Wrap" FontSize="12"
                                                               Text="Copies Text, Number, Choice, Date, Boolean, and Multi-choice column values. Lookup, User, and Managed Metadata columns are not supported."/>
                                                </ToolTip>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                                <Button Margin="20,8,0,0" HorizontalAlignment="Left"
                                        Style="{StaticResource SecondaryBtn}"
                                        Click="ConfigureMappings_Click"
                                        Content="{Binding MappingButtonLabel}"
                                        IsEnabled="{Binding IsColumnsReady}"
                                        Visibility="{Binding CopyCustomColumns, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>

                            <!-- Library scope (individual items): column values always copied — just show mapping button -->
                            <StackPanel Visibility="{Binding IsItemSelectionActive, Converter={StaticResource BoolToVis}}"
                                        Margin="0,4,0,0">
                                <TextBlock Text="Custom column values are always copied for list items."
                                           Style="{StaticResource OptionCaption}" Margin="0,0,0,8"/>
                                <Button HorizontalAlignment="Left"
                                        Style="{StaticResource SecondaryBtn}"
                                        Click="ConfigureMappings_Click"
                                        Content="{Binding MappingButtonLabel}"
                                        IsEnabled="{Binding IsColumnsReady}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── Advanced (hidden for Pages scope) ──────────────────── -->
                    <Button x:Name="AdvancedToggleBtn"
                            Margin="0,8,0,0" Padding="12,9"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                            Background="White" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                            Cursor="Hand" Click="AdvancedToggle_Click"
                            Visibility="{Binding IsPagesScope, Converter={StaticResource InvBoolToVis}}">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Advanced options" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextTertiaryBrush}"/>
                            </StackPanel>
                            <TextBlock x:Name="AdvancedChevron" Text="▾" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>
                    <Border x:Name="AdvancedPanel" Visibility="Collapsed"
                            Background="White" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1,0,1,1"
                            CornerRadius="0,0,6,6" Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="Copy mode" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <RadioButton GroupName="CopyMode" FontSize="12" Margin="0,0,0,6"
                                         IsChecked="{Binding IsMigrationApiMode, Mode=OneWay}"
                                         Click="MigrationApiMode_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Migration API" VerticalAlignment="Center"/>
                                    <Border Background="{StaticResource AccentBrush}" CornerRadius="3" Padding="4,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Recommended" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock Style="{StaticResource ToolTipIcon}" MouseLeftButtonDown="InfoIcon_Click">
                                        <TextBlock.ToolTip>
                                            <ToolTip>
                                                <TextBlock Text="Exact version numbers, dates, and editors. Requires Site Collection Admin on the target." TextWrapping="Wrap" MaxWidth="260"/>
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="CopyMode" FontSize="12" Margin="0,0,0,12"
                                         IsChecked="{Binding IsEnhancedRestMode, Mode=OneWay}"
                                         Click="EnhancedRestMode_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Enhanced REST" VerticalAlignment="Center"/>
                                    <TextBlock Style="{StaticResource ToolTipIcon}" MouseLeftButtonDown="InfoIcon_Click">
                                        <TextBlock.ToolTip>
                                            <ToolTip>
                                                <TextBlock Text="Correct dates and editors per version, but version numbers double (2, 4, 6…). No admin rights required." TextWrapping="Wrap" MaxWidth="260"/>
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                </StackPanel>
                            </RadioButton>
                            <Separator Margin="0,0,0,10" Background="{StaticResource BorderLightBrush}"/>
                            <TextBlock Text="Parallel copies" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <Slider Minimum="1" Maximum="16" Value="{Binding MaxParallelCopies}"
                                        Width="120" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding MaxParallelCopies}" FontSize="14" FontWeight="SemiBold"
                                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Higher values copy faster but may throttle on large sites."
                                       Style="{StaticResource OptionCaption}" Margin="0"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Summary ──────────────────────────────────────────────── -->
                    <Border Style="{StaticResource Card}" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="Summary" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                            <TextBlock FontSize="13"
                                       Visibility="{Binding IsFilesOrPagesScope, Converter={StaticResource BoolToVis}}">
                                <Run Text="Items selected: "/>
                                <Run Text="{Binding CopyJobs.Count, Mode=OneWay}" FontWeight="Bold"/>
                            </TextBlock>
                            <TextBlock FontSize="13"
                                       Visibility="{Binding ShowLibrarySummaryLine, Converter={StaticResource BoolToVis}}">
                                <Run Text="Libraries &amp; lists to copy: "/>
                                <Run Text="{Binding LibrarySummaryCount, Mode=OneWay}" FontWeight="Bold"/>
                            </TextBlock>
                            <TextBlock FontSize="13"
                                       Visibility="{Binding IsItemSelectionActive, Converter={StaticResource BoolToVis}}">
                                <Run Text="List items to copy: "/>
                                <Run Text="{Binding SelectedItemCount, Mode=OneWay}" FontWeight="Bold"/>
                            </TextBlock>
                            <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" TextWrapping="Wrap"
                                       Visibility="{Binding IsFilesScope, Converter={StaticResource BoolToVis}}">
                                Folders are recursively enumerated during the copy.
                            </TextBlock>
                            <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" TextWrapping="Wrap"
                                       Visibility="{Binding IsLibraryOrSiteScope, Converter={StaticResource BoolToVis}}">
                                Files in each library and items in each list are enumerated at copy time.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                  </StackPanel>
                </ScrollViewer>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Copy Preview" Style="{StaticResource SectionHeader}"/>
                    <StackPanel Grid.Row="1" Margin="0,0,0,8">
                        <Border Style="{StaticResource InfoBanner}" Padding="10,6" Margin="0,0,0,4">
                            <TextBlock FontSize="12" TextWrapping="Wrap">
                                <Run Text="From: " FontWeight="SemiBold"/>
                                <Run Text="{Binding SourceUrl}"/>
                            </TextBlock>
                        </Border>
                        <Border Style="{StaticResource InfoBanner}" Padding="10,6">
                            <TextBlock FontSize="12" TextWrapping="Wrap">
                                <Run Text="To: " FontWeight="SemiBold"/>
                                <Run Text="{Binding TargetUrl}"/>
                            </TextBlock>
                        </Border>
                        <Border Style="{StaticResource SuccessBanner}" Padding="10,6" Margin="0,4,0,0"
                                Visibility="{Binding IsItemSelectionActive, Converter={StaticResource BoolToVis}}">
                            <TextBlock FontSize="12" TextWrapping="Wrap">
                                <Run Text="Destination List: " FontWeight="SemiBold"/>
                                <Run Text="{Binding EffectiveDestinationListName, Mode=OneWay}"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <!-- Library / Site scope: list selected libraries -->
                    <Border Grid.Row="2" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1" Background="White"
                            Visibility="{Binding IsLibraryOrSiteScope, Converter={StaticResource BoolToVis}}">
                        <ListView ItemsSource="{Binding LibraryPreviewItems}" Padding="4">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Library / List" Width="220">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding TypeIcon}" Style="{StaticResource GlyphIcon}"
                                                               FontSize="13" Foreground="{StaticResource AccentBrush}" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Destination Name" Width="200">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Style="{StaticResource WatermarkTextBox}"
                                                         Text="{Binding OverrideName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Tag="{Binding Name}"
                                                         FontSize="12" BorderThickness="0,0,0,1"
                                                         BorderBrush="#C8C6C4" Background="Transparent"
                                                         VerticalAlignment="Center" Width="185"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>

                    <!-- Files / Pages scope: list selected file jobs -->
                    <Border Grid.Row="2" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1" Background="White"
                            Visibility="{Binding IsFilesOrPagesScope, Converter={StaticResource BoolToVis}}">
                        <ListView ItemsSource="{Binding CopyJobs}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Type" Width="50">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontFamily="{StaticResource GlyphFont}" FontSize="14"
                                                           Foreground="{StaticResource AccentBrush}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="&#xE7C3;"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                    <Setter Property="Text" Value="&#xE8B7;"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Source Path" Width="360">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SourceDisplayPath}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding SourceDisplayPath}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Destination Path" Width="360">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding TargetDisplayPath}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding TargetDisplayPath}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>
                </Grid>
            </Grid>

            <!-- ── Step 4: Copying Progress ───────────────────────────────── -->
            <Grid Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=4}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHeader}">
                            <Setter Property="Text" Value="Copying Files…"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLibraryOrSiteScope}" Value="True">
                                    <Setter Property="Text" Value="Copying Libraries…"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock FontSize="13">
                                <Run Text="{Binding CompletedCount}"/>
                                <Run Text=" of "/>
                                <Run Text="{Binding TotalCount}"/>
                                <Run Text=" items processed"/>
                            </TextBlock>
                            <TextBlock HorizontalAlignment="Right" FontSize="13" FontWeight="SemiBold">
                                <Run Text="{Binding TotalProgress, StringFormat={}{0:N0}}"/>
                                <Run Text="%"/>
                                <Run Text="   "/>
                                <Run FontFamily="{StaticResource GlyphFont}" Text="&#xE916;" Foreground="{StaticResource TextTertiaryBrush}"/>
                                <Run Text=" " Foreground="{StaticResource TextTertiaryBrush}"/>
                                <Run Text="{Binding ElapsedTime}" Foreground="{StaticResource TextTertiaryBrush}"/>
                            </TextBlock>
                        </Grid>
                        <ProgressBar Value="{Binding TotalProgress}" Maximum="100" Height="12"
                                     Background="{StaticResource BorderLightBrush}" Foreground="{StaticResource AccentBrush}"/>
                        <Button Content="Cancel" Style="{StaticResource DangerBtn}"
                                HorizontalAlignment="Left" Margin="0,12,0,0"
                                Command="{Binding CancelCopyCommand}"
                                Visibility="{Binding IsCopying, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Margin="0,8,0,0" FontSize="13" Foreground="{StaticResource SuccessBrush}"
                                   Visibility="{Binding IsReadyForReport, Converter={StaticResource BoolToVis}}">
                            <Run FontFamily="{StaticResource GlyphFont}" Text="&#xE73E;"/>
                            <Run Text=" Copy complete! Click Next to see the full report."/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                    Visibility="{Binding IsMetadataInProgress, Converter={StaticResource BoolToVis}}">
                            <ProgressBar IsIndeterminate="True" Width="80" Height="4"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Updating folder metadata…" FontSize="13"
                                       Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Margin="0,4,0,0" FontSize="13" Foreground="{StaticResource TextTertiaryBrush}"
                                   Visibility="{Binding IsMetadataComplete, Converter={StaticResource BoolToVis}}">
                            <Run FontFamily="{StaticResource GlyphFont}" Text="&#xE73E;"/>
                            <Run Text=" Metadata updated"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="2" Text="Copy Log" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6"/>
                <Border Grid.Row="3" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1" Background="White">
                    <ListView x:Name="ProgressList" ItemsSource="{Binding CopyResults}"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPermissionResult}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PermissionRowBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Item"     Width="220" DisplayMemberBinding="{Binding FileName}"/>
                                <GridViewColumn Header="Status"   Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StatusDisplay}"
                                                       Foreground="{Binding Status, Converter={StaticResource StatusColor}}"
                                                       FontSize="12"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Source"   Width="260" DisplayMemberBinding="{Binding SourcePath}"/>
                                <GridViewColumn Header="Target"   Width="260" DisplayMemberBinding="{Binding TargetPath}"/>
                                <GridViewColumn Header="Versions" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="12"
                                                       Visibility="{Binding IsLibraryCreation, Converter={StaticResource InvBoolToVis}}">
                                                <Run Text="{Binding VersionsCopied}"/>
                                                <Run Text="/" Foreground="{StaticResource TextTertiaryBrush}"/>
                                                <Run Text="{Binding VersionsTotal}" Foreground="{StaticResource TextTertiaryBrush}"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Details"  Width="220" DisplayMemberBinding="{Binding ErrorMessage}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </Grid>

            <!-- ── Step 5: Report ─────────────────────────────────────────── -->
            <Grid Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=5}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Copy Report" Style="{StaticResource SectionHeader}"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Style="{StaticResource SummaryCard}" Background="{StaticResource SuccessBgBrush}" BorderBrush="{StaticResource SuccessBrush}">
                        <StackPanel>
                            <TextBlock Text="{Binding SuccessCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Succeeded" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryCard}" Background="{StaticResource DangerBgBrush}" BorderBrush="{StaticResource DangerBrush}">
                        <StackPanel>
                            <TextBlock Text="{Binding FailedCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Failed" Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryCard}" Background="{StaticResource WarningBgBrush}" BorderBrush="{StaticResource WarningBrush}">
                        <StackPanel>
                            <TextBlock Text="{Binding SkippedCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource WarningTextBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Skipped" Foreground="{StaticResource WarningTextBrush}" HorizontalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryCard}" Background="{StaticResource WindowBgBrush}" BorderBrush="{StaticResource BorderLightBrush}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="{Binding CopyDuration}" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Duration" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Style="{StaticResource SecondaryBtn}" Command="{Binding ExportReportCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE896;" Style="{StaticResource GlyphIcon}" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="Export CSV" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Row="3" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1">
                    <DataGrid ItemsSource="{Binding CopyResults}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" Background="White"
                              AlternatingRowBackground="#FAFAFA"
                              BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPermissionResult}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PermissionRowBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item"        Binding="{Binding FileName}"   Width="220"/>
                            <DataGridTemplateColumn Header="Status" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StatusDisplay}" Margin="4,2"
                                                   Foreground="{Binding Status, Converter={StaticResource StatusColor}}"
                                                   FontWeight="SemiBold" FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Source Path" Binding="{Binding SourcePath}" Width="260"/>
                            <DataGridTextColumn Header="Target Path" Binding="{Binding TargetPath}" Width="260"/>
                            <DataGridTemplateColumn Header="Versions" Width="65">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding VersionsCopied}" Margin="4,2"
                                                   Visibility="{Binding IsLibraryCreation, Converter={StaticResource InvBoolToVis}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Details"     Binding="{Binding ErrorMessage}"  Width="220"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

        </Grid>

        <!-- ══ Navigation Bar ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="32,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button Content="← Back" Style="{StaticResource SecondaryBtn}"
                            Command="{Binding BackCommand}"
                            AutomationProperties.Name="BackBtn"
                            Visibility="{Binding CurrentStep, Converter={StaticResource NeqToVis}, ConverterParameter=0}"/>
                    <Button Style="{StaticResource SecondaryBtn}"
                            Margin="8,0,0,0"
                            Click="StartNewCopy_Click"
                            Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=5}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" Style="{StaticResource GlyphIcon}" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="Start New Copy" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Button Style="{StaticResource PrimaryBtn}" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Command="{Binding NextCommand}"
                        AutomationProperties.Name="NextBtn"
                        Visibility="{Binding CurrentStep, Converter={StaticResource NeqToVis}, ConverterParameter=5}">
                    <Button.Content>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Next →"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="3">
                                            <Setter Property="Text" Value="▶ Start Copy"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4">
                                            <Setter Property="Text" Value="View Report →"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button.Content>
                </Button>

            </Grid>
        </Border>

    </Grid>
</Window>
