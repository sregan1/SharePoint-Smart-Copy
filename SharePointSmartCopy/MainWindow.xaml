<Window x:Class="SharePointSmartCopy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SharePointSmartCopy.Converters"
        xmlns:vm="clr-namespace:SharePointSmartCopy.ViewModels"
        xmlns:models="clr-namespace:SharePointSmartCopy.Models"
        Title="SharePoint Smart Copy"
        Width="960" Height="720"
        MinWidth="800" MinHeight="600"
        Background="#F3F3F3"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>
        <conv:EqualToVisibilityConverter x:Key="EqToVis"/>
        <conv:NotEqualToVisibilityConverter x:Key="NeqToVis"/>
        <conv:CopyStatusToColorConverter x:Key="StatusColor"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis" Invert="True"/>
        <conv:NullToVisibilityConverter x:Key="NotNullToVis"/>
        <conv:IntToVisibilityConverter x:Key="IntToVis"/>

        <!-- Base button style -->
        <Style x:Key="BaseBtn" TargetType="Button">
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="BorderBrush" Value="#8A8886"/>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#A4262C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#A4262C"/>
        </Style>

        <Style x:Key="LinkBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>

        <!-- TextBox style -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,7"/>
            <Setter Property="BorderBrush" Value="#8A8886"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- TextBox with watermark hint (stored in Tag) -->
        <Style x:Key="WatermarkTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                <TextBlock Text="{TemplateBinding Tag}" Foreground="#A19F9D"
                                           VerticalAlignment="Center" IsHitTestVisible="False"
                                           FontSize="{TemplateBinding FontSize}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1F1F1F"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SubHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#605E5C"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <!-- Field label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- TreeViewItem override for checkboxes -->
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <!-- HierarchicalDataTemplate for source tree -->
        <HierarchicalDataTemplate x:Key="SourceNodeTemplate"
                                  DataType="{x:Type models:SharePointNode}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2,2">
                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                          Checked="SourceNode_CheckChanged" Unchecked="SourceNode_CheckChanged"
                          VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding TypeIcon}" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"/>
                <TextBlock Text="{Binding SizeDisplay}" Foreground="#797775" FontSize="11"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                <ProgressBar IsIndeterminate="True" Width="60" Height="4" Margin="8,0,0,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- HierarchicalDataTemplate for target tree (folders only, radio-style) -->
        <HierarchicalDataTemplate x:Key="TargetNodeTemplate"
                                  DataType="{x:Type models:SharePointNode}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2,2">
                <TextBlock Text="{Binding TypeIcon}" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"/>
                <ProgressBar IsIndeterminate="True" Width="60" Height="4" Margin="8,0,0,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- Step badge -->
        <Style x:Key="StepDot" TargetType="Border">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Background" Value="#EDEBE9"/>
        </Style>
        <Style x:Key="StepDotActive" TargetType="Border" BasedOn="{StaticResource StepDot}">
            <Setter Property="Background" Value="#0078D4"/>
        </Style>
        <Style x:Key="StepDotDone" TargetType="Border" BasedOn="{StaticResource StepDot}">
            <Setter Property="Background" Value="#107C10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>   <!-- App bar -->
            <RowDefinition Height="Auto"/> <!-- Step indicator -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="64"/>   <!-- Nav bar -->
        </Grid.RowDefinitions>

        <!-- ══ App Bar ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#0078D4">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="6" Background="White" Padding="3"
                            VerticalAlignment="Center" Margin="0,0,10,0">
                        <Image RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Source>
                                <CroppedBitmap Source="pack://application:,,,/Resources/logo.png"
                                               SourceRect="0,0,625,415"/>
                            </Image.Source>
                        </Image>
                    </Border>
                    <TextBlock Text="SharePoint Smart Copy" FontSize="16" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding AuthService.UserName}" Foreground="White" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,12,0"
                               Visibility="{Binding AuthService.IsAuthenticated, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="📋 History" Style="{StaticResource BaseBtn}"
                            Background="Transparent" Foreground="White" BorderBrush="#80FFFFFF"
                            Padding="12,6" FontSize="12" Margin="0,0,8,0" Click="HistoryButton_Click"/>
                    <Button Content="⚙ Settings" Style="{StaticResource BaseBtn}"
                            Background="Transparent" Foreground="White" BorderBrush="#80FFFFFF"
                            Padding="12,6" FontSize="12" Click="SettingsButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Step Indicator ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="White" BorderBrush="#EDEBE9" BorderThickness="0,0,0,1" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel.Resources>
                    <Style x:Key="StepText" TargetType="TextBlock">
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Foreground" Value="#797775"/>
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="Margin" Value="0,2,0,0"/>
                    </Style>
                </StackPanel.Resources>

                <!-- Steps: Source, Browse, Target, Options, Copy, Report -->
                <StackPanel x:Name="StepSource">
                    <Border Width="28" Height="28" CornerRadius="14" HorizontalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#EDEBE9"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="0">
                                        <Setter Property="Background" Value="#0078D4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontWeight="Bold" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#797775"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="0">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <TextBlock Text="Source" Style="{StaticResource StepText}"/>
                </StackPanel>

                <Border Height="2" Width="40" Background="#EDEBE9" VerticalAlignment="Top" Margin="4,13,4,0"/>

                <StackPanel>
                    <Border Width="28" Height="28" CornerRadius="14" HorizontalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#EDEBE9"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="1">
                                        <Setter Property="Background" Value="#0078D4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontWeight="Bold" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#797775"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="1">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <TextBlock Text="Browse" Style="{StaticResource StepText}"/>
                </StackPanel>

                <Border Height="2" Width="40" Background="#EDEBE9" VerticalAlignment="Top" Margin="4,13,4,0"/>

                <StackPanel>
                    <Border Width="28" Height="28" CornerRadius="14" HorizontalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#EDEBE9"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                        <Setter Property="Background" Value="#0078D4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontWeight="Bold" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#797775"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <TextBlock Text="Target" Style="{StaticResource StepText}"/>
                </StackPanel>

                <Border Height="2" Width="40" Background="#EDEBE9" VerticalAlignment="Top" Margin="4,13,4,0"/>

                <StackPanel>
                    <Border Width="28" Height="28" CornerRadius="14" HorizontalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#EDEBE9"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="3">
                                        <Setter Property="Background" Value="#0078D4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="4" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontWeight="Bold" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#797775"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="3">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <TextBlock Text="Options" Style="{StaticResource StepText}"/>
                </StackPanel>

                <Border Height="2" Width="40" Background="#EDEBE9" VerticalAlignment="Top" Margin="4,13,4,0"/>

                <StackPanel>
                    <Border Width="28" Height="28" CornerRadius="14" HorizontalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#EDEBE9"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="4">
                                        <Setter Property="Background" Value="#0078D4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="5" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontWeight="Bold" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#797775"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <TextBlock Text="Copy" Style="{StaticResource StepText}"/>
                </StackPanel>

                <Border Height="2" Width="40" Background="#EDEBE9" VerticalAlignment="Top" Margin="4,13,4,0"/>

                <StackPanel>
                    <Border Width="28" Height="28" CornerRadius="14" HorizontalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#EDEBE9"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentStep}" Value="5">
                                        <Setter Property="Background" Value="#107C10"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="✓" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontWeight="Bold" FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#797775"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="5">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <TextBlock Text="Report" Style="{StaticResource StepText}"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ══ Content Area ═════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="32,24">

                <!-- ── Step 0: Source URL ─────────────────────────────────────── -->
                <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=0}"
                            MaxWidth="520" HorizontalAlignment="Left">

                    <TextBlock Text="Connect to Source Site" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Style="{StaticResource SubHeader}">
                        Enter the URL of the SharePoint site collection you want to copy <Run FontStyle="Italic">from</Run>.
                    </TextBlock>

                    <TextBlock Text="Source Site URL" Style="{StaticResource FieldLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding SourceUrl, UpdateSourceTrigger=PropertyChanged}"
                                 x:Name="SourceUrlBox"
                                 Tag="https://contoso.sharepoint.com/sites/source"
                                 Style="{StaticResource WatermarkTextBox}"/>
                        <Button Grid.Column="2" Content="Connect" Style="{StaticResource PrimaryBtn}"
                                Command="{Binding ConnectSourceCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvBoolToVis}}"/>
                    </Grid>

                    <TextBlock Text="{Binding SourceStatus}" FontSize="13" Margin="0,12,0,0"
                               Visibility="{Binding SourceStatus, Converter={StaticResource NotNullToVis}}"/>

                    <Border Background="#EFF6FC" BorderBrush="#0078D4" BorderThickness="1"
                            CornerRadius="4" Padding="14,10" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="💡 Requirements" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#323130" LineHeight="20">
                                • You must have read access to the source site collection.&#10;
                                • Configure your Azure AD app ID in Settings (⚙) before connecting.&#10;
                                • Admin consent is required for Sites.ReadWrite.All and Files.ReadWrite.All.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <ProgressBar IsIndeterminate="True" Height="4" Margin="0,16,0,0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <!-- ── Step 1: Browse Source ──────────────────────────────────── -->
                <Grid Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=1}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Select Files to Copy" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Grid.Row="1" Style="{StaticResource SubHeader}">
                        Expand libraries and check items to copy. Checking a folder selects all its contents.
                    </TextBlock>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Select All" Style="{StaticResource LinkBtn}" Click="SelectAll_Click"/>
                        <TextBlock Text=" | " Foreground="#EDEBE9" VerticalAlignment="Center"/>
                        <Button Content="Deselect All" Style="{StaticResource LinkBtn}" Click="DeselectAll_Click"/>
                        <ProgressBar IsIndeterminate="True" Width="80" Height="4" Margin="16,0,0,0" VerticalAlignment="Center"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#605E5C" FontSize="12"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="3" BorderBrush="#EDEBE9" BorderThickness="1"
                            Background="White" MinHeight="300">
                        <TreeView x:Name="SourceTreeView"
                                  ItemsSource="{Binding SourceLibraries}"
                                  ItemTemplate="{StaticResource SourceNodeTemplate}"
                                  Padding="4">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <EventSetter Event="Expanded" Handler="SourceTreeItem_Expanded"/>
                                </Style>
                            </TreeView.ItemContainerStyle>
                        </TreeView>
                    </Border>
                </Grid>

                <!-- ── Step 2: Target URL + Folder ───────────────────────────── -->
                <Grid Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=2}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: connect -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Connect to Target Site" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Style="{StaticResource SubHeader}">
                            Enter the URL of the destination site collection.
                        </TextBlock>

                        <TextBlock Text="Target Site URL" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding TargetUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="https://contoso.sharepoint.com/sites/target"
                                 Style="{StaticResource WatermarkTextBox}"
                                 Margin="0,0,0,8"/>
                        <Button Content="Connect to Target" Style="{StaticResource PrimaryBtn}"
                                HorizontalAlignment="Left"
                                Command="{Binding ConnectTargetCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvBoolToVis}}"/>

                        <TextBlock Text="{Binding TargetStatus}" FontSize="13" Margin="0,8,0,0"
                                   Visibility="{Binding TargetStatus, Converter={StaticResource NotNullToVis}}"/>

                        <ProgressBar IsIndeterminate="True" Height="4" Margin="0,12,0,0"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

                        <Border Background="#FFF4CE" BorderBrush="#F7B900" BorderThickness="1"
                                CornerRadius="4" Padding="12,8" Margin="0,20,0,0">
                            <TextBlock TextWrapping="Wrap" FontSize="12">
                                Select the destination folder in the tree on the right.
                                Files will be copied into that folder.
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <!-- Right: target folder tree -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Select Destination Folder" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Style="{StaticResource SubHeader}">
                            Click a library or folder to select it as the copy destination.
                        </TextBlock>

                        <Border Background="#E6F2FB" BorderBrush="#0078D4" BorderThickness="1"
                                CornerRadius="4" Padding="10,6" Margin="0,0,0,8"
                                Visibility="{Binding SelectedTargetFolder, Converter={StaticResource NullToVis}}">
                            <TextBlock FontSize="13">
                                <Run Text="📁 Selected: "/>
                                <Run Text="{Binding SelectedTargetFolder.Name}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </Border>

                        <Border BorderBrush="#EDEBE9" BorderThickness="1" Background="White" MinHeight="300">
                            <TreeView x:Name="TargetTreeView"
                                      ItemsSource="{Binding TargetLibraries}"
                                      ItemTemplate="{StaticResource TargetNodeTemplate}"
                                      SelectedItemChanged="TargetTree_SelectedItemChanged"
                                      Padding="4">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        <EventSetter Event="Expanded" Handler="TargetTreeItem_Expanded"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ── Step 3: Options + Review ───────────────────────────────── -->
                <Grid Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=3}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Options panel -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Copy Options" Style="{StaticResource SectionHeader}"/>

                        <Border Background="White" BorderBrush="#EDEBE9" BorderThickness="1"
                                CornerRadius="6" Padding="16" Margin="0,8,0,0">
                            <StackPanel>
                                <CheckBox Content="Overwrite existing files"
                                          IsChecked="{Binding OverwriteFiles}"
                                          Margin="0,0,0,12" FontSize="13"/>

                                <CheckBox Content="Copy versions"
                                          IsChecked="{Binding CopyVersions}"
                                          Margin="0,0,0,4" FontSize="13"/>
                                <TextBlock TextWrapping="Wrap" Foreground="#797775" FontSize="11"
                                           Margin="20,0,0,8"
                                           Text="Copies file version history to the target. Versions are uploaded oldest-first so history builds naturally. Original timestamps and author info are preserved on each version."/>

                                <!-- Version sub-options — visible only when Copy Versions is checked -->
                                <StackPanel Visibility="{Binding CopyVersions, Converter={StaticResource BoolToVis}}"
                                            Margin="20,0,0,12">
                                    <CheckBox Content="Copy all versions"
                                              IsChecked="{Binding CopyAllVersions}"
                                              FontSize="12" Margin="0,0,0,6"/>
                                    <!-- N input — grayed out when Copy All Versions is checked -->
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="IsEnabled" Value="True"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CopyAllVersions}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Latest " FontSize="12" Foreground="#323130" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding MaxVersions, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="52" FontSize="12" Padding="6,4" VerticalAlignment="Center"/>
                                        <TextBlock Text=" versions" FontSize="12" Foreground="#797775" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Text="Parallel copies" Style="{StaticResource FieldLabel}"/>
                                <StackPanel Orientation="Horizontal">
                                    <Slider Minimum="1" Maximum="16"
                                            Value="{Binding MaxParallelCopies}"
                                            Width="120" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding MaxParallelCopies}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Higher values copy faster but may throttle on large sites."
                                           TextWrapping="Wrap" Foreground="#797775" FontSize="11" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" BorderBrush="#EDEBE9" BorderThickness="1"
                                CornerRadius="6" Padding="16" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="Summary" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                                <TextBlock FontSize="13">
                                    <Run Text="Items selected: "/>
                                    <Run Text="{Binding CopyJobs.Count, Mode=OneWay}" FontWeight="Bold"/>
                                </TextBlock>
                                <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="#605E5C" TextWrapping="Wrap">
                                    Folders will be recursively enumerated during the copy.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Preview list -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Copy Preview" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Style="{StaticResource SubHeader}">
                            Review what will be copied and where. Folder contents will be discovered during copy.
                        </TextBlock>

                        <Border BorderBrush="#EDEBE9" BorderThickness="1" Background="White">
                            <ListView ItemsSource="{Binding CopyJobs}" MaxHeight="450">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Type" Width="50">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock FontSize="14" HorizontalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="📄"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                        <Setter Property="Text" Value="📁"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Source" Width="260"
                                                        DisplayMemberBinding="{Binding SourceDisplayPath}"/>
                                        <GridViewColumn Header="Destination" Width="220"
                                                        DisplayMemberBinding="{Binding TargetDisplayPath}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ── Step 4: Copying Progress ───────────────────────────────── -->
                <Grid Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=4}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Copying Files…" Style="{StaticResource SectionHeader}"/>

                    <!-- Overall progress -->
                    <Border Grid.Row="1" Background="White" BorderBrush="#EDEBE9" BorderThickness="1"
                            CornerRadius="6" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock FontSize="13">
                                    <Run Text="{Binding CompletedCount}"/>
                                    <Run Text=" of "/>
                                    <Run Text="{Binding TotalCount}"/>
                                    <Run Text=" files processed"/>
                                </TextBlock>
                                <TextBlock HorizontalAlignment="Right" FontSize="13" FontWeight="SemiBold">
                                    <Run Text="{Binding TotalProgress, StringFormat={}{0:N0}}"/>
                                    <Run Text="%"/>
                                    <Run Text="   ⏱ " Foreground="#797775"/>
                                    <Run Text="{Binding ElapsedTime}" Foreground="#797775"/>
                                </TextBlock>
                            </Grid>
                            <ProgressBar Value="{Binding TotalProgress}" Maximum="100" Height="12"
                                         Background="#EDEBE9" Foreground="#0078D4"/>
                            <Button Content="Cancel" Style="{StaticResource DangerBtn}"
                                    HorizontalAlignment="Left" Margin="0,12,0,0"
                                    Command="{Binding CancelCopyCommand}"
                                    Visibility="{Binding IsCopying, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Margin="0,8,0,0" FontSize="13" Foreground="#107C10"
                                       Text="✅ Copy complete! Click Next to see the full report."
                                       Visibility="{Binding IsCopyComplete, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Live file list -->
                    <TextBlock Grid.Row="2" Text="File Status" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6"/>
                    <Border Grid.Row="3" BorderBrush="#EDEBE9" BorderThickness="1" Background="White">
                        <ListView x:Name="ProgressList" ItemsSource="{Binding CopyResults}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="File"     Width="220" DisplayMemberBinding="{Binding FileName}"/>
                                    <GridViewColumn Header="Status"   Width="110">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StatusDisplay}"
                                                           Foreground="{Binding Status, Converter={StaticResource StatusColor}}"
                                                           FontSize="12"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Source"   Width="260" DisplayMemberBinding="{Binding SourcePath}"/>
                                    <GridViewColumn Header="Target"   Width="260" DisplayMemberBinding="{Binding TargetPath}"/>
                                    <GridViewColumn Header="Versions" Width="70">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock FontSize="12">
                                                    <Run Text="{Binding VersionsCopied}"/>
                                                    <Run Text="/" Foreground="#797775"/>
                                                    <Run Text="{Binding VersionsTotal}" Foreground="#797775"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Error"    Width="220" DisplayMemberBinding="{Binding ErrorMessage}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>
                </Grid>

                <!-- ── Step 5: Report ─────────────────────────────────────────── -->
                <Grid Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=5}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Copy Report" Style="{StaticResource SectionHeader}"/>

                    <!-- Summary cards -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Background="#DFF6DD" BorderBrush="#107C10" BorderThickness="1"
                                CornerRadius="6" Padding="20,12" Margin="0,0,12,0" MinWidth="130">
                            <StackPanel>
                                <TextBlock Text="{Binding SuccessCount}" FontSize="28" FontWeight="Bold"
                                           Foreground="#107C10" HorizontalAlignment="Center"/>
                                <TextBlock Text="Succeeded" Foreground="#107C10" HorizontalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FDE7E9" BorderBrush="#A4262C" BorderThickness="1"
                                CornerRadius="6" Padding="20,12" Margin="0,0,12,0" MinWidth="130">
                            <StackPanel>
                                <TextBlock Text="{Binding FailedCount}" FontSize="28" FontWeight="Bold"
                                           Foreground="#A4262C" HorizontalAlignment="Center"/>
                                <TextBlock Text="Failed" Foreground="#A4262C" HorizontalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FFF4CE" BorderBrush="#F7B900" BorderThickness="1"
                                CornerRadius="6" Padding="20,12" Margin="0,0,12,0" MinWidth="130">
                            <StackPanel>
                                <TextBlock Text="{Binding SkippedCount}" FontSize="28" FontWeight="Bold"
                                           Foreground="#7A5900" HorizontalAlignment="Center"/>
                                <TextBlock Text="Skipped" Foreground="#7A5900" HorizontalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F3F2F1" BorderBrush="#EDEBE9" BorderThickness="1"
                                CornerRadius="6" Padding="20,12" MinWidth="130">
                            <StackPanel>
                                <TextBlock Text="{Binding CopyDuration}" FontSize="28" FontWeight="Bold"
                                           Foreground="#323130" HorizontalAlignment="Center"/>
                                <TextBlock Text="Duration" Foreground="#605E5C" HorizontalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="📥 Export CSV" Style="{StaticResource SecondaryBtn}"
                                Command="{Binding ExportReportCommand}"/>
                        <Button Content="🔄 Start New Copy" Style="{StaticResource PrimaryBtn}"
                                Margin="8,0,0,0" Click="StartNewCopy_Click"/>
                    </StackPanel>

                    <!-- Full report grid -->
                    <Border Grid.Row="3" BorderBrush="#EDEBE9" BorderThickness="1">
                        <DataGrid ItemsSource="{Binding CopyResults}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column" Background="White"
                                  AlternatingRowBackground="#FAFAFA"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="File Name"   Binding="{Binding FileName}"   Width="220"/>
                                <DataGridTemplateColumn Header="Status" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StatusDisplay}" Margin="4,2"
                                                       Foreground="{Binding Status, Converter={StaticResource StatusColor}}"
                                                       FontWeight="SemiBold" FontSize="12"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Source Path" Binding="{Binding SourcePath}" Width="260"/>
                                <DataGridTextColumn Header="Target Path" Binding="{Binding TargetPath}" Width="260"/>
                                <DataGridTextColumn Header="Versions"    Binding="{Binding VersionsCopied}" Width="65"/>
                                <DataGridTextColumn Header="Error"       Binding="{Binding ErrorMessage}"  Width="220"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

        </Grid>

        <!-- ══ Navigation Bar ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="White" BorderBrush="#EDEBE9" BorderThickness="0,1,0,0">
            <Grid Margin="32,0">
                <Button Content="← Back" Style="{StaticResource SecondaryBtn}"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Command="{Binding BackCommand}"
                        Visibility="{Binding CurrentStep, Converter={StaticResource NeqToVis}, ConverterParameter=5}"/>

                <!-- Step-specific next labels -->
                <Button Style="{StaticResource PrimaryBtn}" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Command="{Binding NextCommand}"
                        Visibility="{Binding CurrentStep, Converter={StaticResource NeqToVis}, ConverterParameter=5}">
                    <Button.Content>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Next →"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="3">
                                            <Setter Property="Text" Value="▶ Start Copy"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4">
                                            <Setter Property="Text" Value="View Report →"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button.Content>
                </Button>

                <!-- On the last step, no next button -->
            </Grid>
        </Border>

    </Grid>
</Window>
