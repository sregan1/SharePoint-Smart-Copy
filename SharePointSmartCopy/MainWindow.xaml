<Window x:Class="SharePointSmartCopy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SharePointSmartCopy.Converters"
        xmlns:vm="clr-namespace:SharePointSmartCopy.ViewModels"
        xmlns:models="clr-namespace:SharePointSmartCopy.Models"
        Title="SharePoint Smart Copy"
        Width="960" Height="720"
        MinWidth="800" MinHeight="600"
        Background="{DynamicResource WindowBgBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None">

    <!-- Custom chrome: the blue app bar (row 0, 52px) doubles as the title bar.
         Buttons inside it opt in via WindowChrome.IsHitTestVisibleInChrome. -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="52"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>
        <conv:EqualToVisibilityConverter x:Key="EqToVis"/>
        <conv:NotEqualToVisibilityConverter x:Key="NeqToVis"/>
        <conv:CopyStatusToColorConverter x:Key="StatusColor"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis" Invert="True"/>
        <conv:NullToVisibilityConverter x:Key="NotNullToVis"/>
        <conv:IntToVisibilityConverter x:Key="IntToVis"/>
        <conv:InvertBoolConverter x:Key="InvBool"/>
        <conv:MultiEqualToBoolConverter x:Key="MultiEqual"/>
        <conv:MultiGreaterThanToBoolConverter x:Key="MultiGreater"/>
        <conv:EqualToBoolConverter x:Key="EqToBool"/>

        <!-- ── Wizard step definitions ── -->
        <x:Array x:Key="WizardSteps" Type="models:StepInfo">
            <models:StepInfo Index="0" Display="1" Label="Source"/>
            <models:StepInfo Index="1" Display="2" Label="Browse"/>
            <models:StepInfo Index="2" Display="3" Label="Target"/>
            <models:StepInfo Index="3" Display="4" Label="Options"/>
            <models:StepInfo Index="4" Display="5" Label="Copy"/>
            <models:StepInfo Index="5" Display="✓" Label="Report" IsFinal="True"/>
        </x:Array>

        <!-- Bubble for one wizard step: gray when upcoming, light accent with a check
             when completed, accent when current, green for the final (Report) step.
             DataContext is a StepInfo. -->
        <Style x:Key="StepBubble" TargetType="Border">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Background" Value="{DynamicResource BorderLightBrush}"/>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource MultiGreater}">
                            <Binding Path="DataContext.CurrentStep" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            <Binding Path="Index"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                </DataTrigger>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource MultiEqual}">
                            <Binding Path="DataContext.CurrentStep" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            <Binding Path="Index"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Value="True">
                            <Condition.Binding>
                                <MultiBinding Converter="{StaticResource MultiEqual}">
                                    <Binding Path="DataContext.CurrentStep" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    <Binding Path="Index"/>
                                </MultiBinding>
                            </Condition.Binding>
                        </Condition>
                        <Condition Binding="{Binding IsFinal}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Text binding lives in the style (not the element) so triggers can override it -->
        <Style x:Key="StepBubbleText" TargetType="TextBlock">
            <Setter Property="Text" Value="{Binding Display}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource MultiGreater}">
                            <Binding Path="DataContext.CurrentStep" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            <Binding Path="Index"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Text" Value="✓"/>
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                </DataTrigger>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource MultiEqual}">
                            <Binding Path="DataContext.CurrentStep" RelativeSource="{RelativeSource AncestorType=Window}"/>
                            <Binding Path="Index"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ── Mode tile: Button (keyboard + screen-reader accessible) whose Tag
             carries the scope's Is*Scope binding. Hover/focus show an accent border. ── -->
        <Style x:Key="ModeTileButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLightBrush}"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="110"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="2" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Top"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModeTileGlyph" TargetType="TextBlock" BasedOn="{StaticResource GlyphIcon}">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModeTileTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModeTileDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource TileSelectedTextBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ── Window caption buttons (min / max / close) ── -->
        <Style x:Key="CaptionBtn" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CaptionCloseBtn" TargetType="Button" BasedOn="{StaticResource CaptionBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <!-- CheckBox with three visual states: empty (false), checkmark (true), dash (null/indeterminate) -->
        <Style x:Key="ItemsOnlyCheckBox" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent" SnapsToDevicePixels="True">
                            <BulletDecorator.Bullet>
                                <Border x:Name="Box" Width="14" Height="14" CornerRadius="2"
                                        BorderBrush="{DynamicResource BorderInputBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}">
                                    <Grid>
                                        <Path x:Name="Check" Visibility="Collapsed"
                                              Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.8" StrokeLineJoin="Round"
                                              Data="M2,7 L5.5,10.5 L12,3.5"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Rectangle x:Name="Dash" Visibility="Collapsed"
                                                   Width="7" Height="2" Fill="{DynamicResource AccentBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="{x:Null}">
                                <Setter TargetName="Dash" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <HierarchicalDataTemplate x:Key="SourceNodeTemplate"
                                  DataType="{x:Type models:SharePointNode}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2,2">
                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                          Style="{StaticResource ItemsOnlyCheckBox}"
                          IsThreeState="True"
                          Checked="SourceNode_CheckChanged"
                          Unchecked="SourceNode_CheckChanged"
                          Indeterminate="SourceNode_CheckChanged"
                          PreviewMouseLeftButtonDown="SourceCheckBox_PreviewClick"
                          VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding TypeIcon}" Style="{StaticResource GlyphIcon}"
                           Foreground="{DynamicResource AccentBrush}" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"/>
                <TextBlock Text="{Binding SizeDisplay}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                <ProgressBar IsIndeterminate="True" Width="60" Height="4" Margin="8,0,0,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <HierarchicalDataTemplate x:Key="TargetNodeTemplate"
                                  DataType="{x:Type models:SharePointNode}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2,2">
                <TextBlock Text="{Binding TypeIcon}" Style="{StaticResource GlyphIcon}"
                           Foreground="{DynamicResource AccentBrush}" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"/>
                <ProgressBar IsIndeterminate="True" Width="60" Height="4" Margin="8,0,0,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid TextElement.Foreground="{DynamicResource TextPrimaryBrush}">
        <Grid.Style>
            <Style TargetType="Grid">
                <Style.Triggers>
                    <!-- Maximized borderless windows overhang the screen by the resize
                         border width — pad the content back into view. -->
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}"
                                 Value="Maximized">
                        <Setter Property="Margin" Value="7"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <!-- ══ App Bar (doubles as the window title bar) ════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource AccentBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="16,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="36" Height="36" CornerRadius="6" Background="White" Padding="3"
                                VerticalAlignment="Center" Margin="0,0,10,0">
                            <Image RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Source>
                                    <CroppedBitmap Source="pack://application:,,,/Resources/logo.png"
                                                   SourceRect="0,0,625,415"/>
                                </Image.Source>
                            </Image>
                        </Border>
                        <TextBlock Text="SharePoint Smart Copy" FontSize="16" FontWeight="SemiBold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SignedInUser}" Foreground="White" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,12,0"
                                   Visibility="{Binding SignedInUser, Converter={StaticResource NotNullToVis}}"/>
                        <Button Style="{StaticResource AppBarBtn}" Margin="0,0,8,0" Click="HistoryButton_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE81C;" Style="{StaticResource GlyphIcon}" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="History" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource AppBarBtn}" Click="SettingsButton_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" Style="{StaticResource GlyphIcon}" FontSize="13" Margin="0,0,6,0"/>
                                <TextBlock Text="Settings" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Window caption buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource CaptionBtn}" Click="Minimize_Click"
                            AutomationProperties.Name="Minimize">
                        <TextBlock Text="&#xE921;" FontFamily="{StaticResource GlyphFont}" FontSize="10"/>
                    </Button>
                    <Button Style="{StaticResource CaptionBtn}" Click="MaximizeRestore_Click"
                            AutomationProperties.Name="Maximize or restore">
                        <TextBlock FontFamily="{StaticResource GlyphFont}" FontSize="10">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE922;"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}"
                                                     Value="Maximized">
                                            <Setter Property="Text" Value="&#xE923;"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Style="{StaticResource CaptionCloseBtn}" Click="CloseWindow_Click"
                            AutomationProperties.Name="Close">
                        <TextBlock Text="&#xE8BB;" FontFamily="{StaticResource GlyphFont}" FontSize="10"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Step Indicator ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderLightBrush}"
                BorderThickness="0,0,0,1" Padding="20,12">
            <ItemsControl ItemsSource="{StaticResource WizardSteps}" HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:StepInfo}">
                        <StackPanel Orientation="Horizontal">
                            <Border Height="2" Width="40" Background="{DynamicResource BorderLightBrush}"
                                    VerticalAlignment="Top" Margin="4,13,4,0"
                                    Visibility="{Binding Index, Converter={StaticResource IntToVis}}"/>
                            <StackPanel>
                                <Border Style="{StaticResource StepBubble}">
                                    <TextBlock Style="{StaticResource StepBubbleText}"/>
                                </Border>
                                <TextBlock Text="{Binding Label}" Style="{StaticResource StepText}"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- ══ Content Area ═════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="32,24">

            <!-- ── Step 0: Source URL ─────────────────────────────────────── -->
            <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=0}"
                        MaxWidth="560" HorizontalAlignment="Center" Margin="0,32,0,0">

                <TextBlock Text="Connect to Source Site" Style="{StaticResource SectionHeader}"/>
                <TextBlock Style="{StaticResource SubHeader}">
                    Enter the URL of the SharePoint site collection you want to copy <Run FontStyle="Italic">from</Run>.
                </TextBlock>

                <TextBlock Text="Source Site URL" Style="{StaticResource FieldLabel}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding SourceUrl, UpdateSourceTrigger=PropertyChanged}"
                             Tag="https://contoso.sharepoint.com/sites/source"
                             Style="{StaticResource WatermarkTextBox}"/>
                    <Grid Grid.Column="2">
                        <Button Content="Connect" Style="{StaticResource PrimaryBtn}"
                                Command="{Binding ConnectSourceCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                                Visibility="{Binding IsConnectingSource, Converter={StaticResource InvBoolToVis}}"/>
                        <Button Content="Disconnect" Style="{StaticResource DangerBtn}"
                                Command="{Binding CancelConnectSourceCommand}"
                                Visibility="{Binding IsConnectingSource, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                            Visibility="{Binding SourceStatus, Converter={StaticResource NotNullToVis}}">
                    <TextBlock Text="{Binding SourceStatus}" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text=" · " Foreground="{DynamicResource TextPlaceholderBrush}" FontSize="13" VerticalAlignment="Center"
                               Visibility="{Binding SourceConnected, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="Disconnect" Style="{StaticResource LinkBtn}"
                            Command="{Binding DisconnectSourceCommand}"
                            Foreground="{DynamicResource TextTertiaryBrush}" FontSize="13" Padding="0" VerticalAlignment="Center"
                            Visibility="{Binding SourceConnected, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <Border Style="{StaticResource InfoBanner}" Padding="14,10" Margin="0,20,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="&#xEA80;" Style="{StaticResource GlyphIcon}"
                                       Foreground="{DynamicResource AccentBrush}" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="Requirements" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" LineHeight="20">
                            <Run>• You must have read access to the source site collection.</Run>
                            <LineBreak/>
                            <Run>• Configure your Azure AD app ID in Settings before connecting.</Run>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,16,0,0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <!-- ── Step 1: Browse Source ──────────────────────────────────── -->
            <!-- Outer scroll so the whole step stays reachable when the expanded source tree + headers
                 exceed the window height (small windows or deeply expanded folders). The tree keeps its
                 own internal scroll via the MaxHeight on its Border below; this viewer scrolls the
                 surrounding chrome. Trees are non-virtualized, so wrapping them costs no virtualization. -->
            <ScrollViewer Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=1}"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="What would you like to copy?" Style="{StaticResource SectionHeader}"/>

                <!-- ── Mode tile selector ── -->
                <UniformGrid Grid.Row="1" Columns="4" Margin="0,8,0,12">
                    <Button Style="{StaticResource ModeTileButton}" Tag="{Binding IsFilesScope}"
                            Click="ModeFiles_Click"
                            AutomationProperties.Name="Files and Folders mode">
                        <StackPanel>
                            <TextBlock Text="&#xE7C3;" Style="{StaticResource ModeTileGlyph}"/>
                            <TextBlock Text="Files &amp; Folders" Style="{StaticResource ModeTileTitle}"/>
                            <TextBlock Text="Copy individual files between libraries" Style="{StaticResource ModeTileDesc}"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ModeTileButton}" Tag="{Binding IsLibraryScope}"
                            Click="ModeLibrary_Click"
                            AutomationProperties.Name="Libraries and Lists mode">
                        <StackPanel>
                            <TextBlock Text="&#xE8F1;" Style="{StaticResource ModeTileGlyph}"/>
                            <TextBlock Text="Libraries &amp; Lists" Style="{StaticResource ModeTileTitle}"/>
                            <TextBlock Text="Recreate libraries &amp; lists with structure and columns" Style="{StaticResource ModeTileDesc}"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ModeTileButton}" Tag="{Binding IsSiteScope}"
                            Click="ModeSite_Click"
                            AutomationProperties.Name="Entire Site mode">
                        <StackPanel>
                            <TextBlock Text="&#xE774;" Style="{StaticResource ModeTileGlyph}"/>
                            <TextBlock Text="Entire Site" Style="{StaticResource ModeTileTitle}"/>
                            <TextBlock Text="Copy all libraries from the source site" Style="{StaticResource ModeTileDesc}"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ModeTileButton}" Tag="{Binding IsPagesScope}" Margin="0"
                            Click="ModePages_Click"
                            AutomationProperties.Name="Site Pages mode">
                        <StackPanel>
                            <TextBlock Text="&#xE8A1;" Style="{StaticResource ModeTileGlyph}"/>
                            <TextBlock Text="Site Pages" Style="{StaticResource ModeTileTitle}"/>
                            <TextBlock Text="Copy modern pages with web parts" Style="{StaticResource ModeTileDesc}"/>
                        </StackPanel>
                    </Button>
                </UniformGrid>

                <Border Grid.Row="2" Style="{StaticResource InfoBanner}" Padding="10,6" Margin="0,0,0,8">
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis">
                        <Run Text="Source: " FontWeight="SemiBold"/>
                        <Run Text="{Binding SourceUrl}"/>
                    </TextBlock>
                </Border>

                <!-- Scope-specific subheader -->
                <TextBlock Grid.Row="3" Style="{StaticResource SubHeader}"
                           Visibility="{Binding IsFilesScope, Converter={StaticResource BoolToVis}}">
                    Expand libraries and check the files or folders you want to copy.
                </TextBlock>
                <TextBlock Grid.Row="3" Style="{StaticResource SubHeader}"
                           Visibility="{Binding IsLibraryScope, Converter={StaticResource BoolToVis}}">
                    Check the libraries and lists you want to recreate at the target site.
                </TextBlock>
                <TextBlock Grid.Row="3" Style="{StaticResource SubHeader}"
                           Visibility="{Binding IsPagesScope, Converter={StaticResource BoolToVis}}">
                    Check the pages you want to copy. Use Select All to copy the entire Site Pages library.
                </TextBlock>
                <TextBlock Grid.Row="3" Style="{StaticResource SubHeader}"
                           Visibility="{Binding IsSiteScope, Converter={StaticResource BoolToVis}}">
                    All libraries from the source site will be copied. Connect the target to continue.
                </TextBlock>

                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,8"
                            Visibility="{Binding IsSiteScope, Converter={StaticResource InvBoolToVis}}">
                    <Button Content="Select All" Style="{StaticResource LinkBtn}" Click="SelectAll_Click"/>
                    <TextBlock Text=" | " Foreground="{DynamicResource BorderLightBrush}" VerticalAlignment="Center"/>
                    <Button Content="Deselect All" Style="{StaticResource LinkBtn}" Click="DeselectAll_Click"/>
                    <ProgressBar IsIndeterminate="True" Width="80" Height="4" Margin="16,0,0,0" VerticalAlignment="Center"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <Border Grid.Row="5" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1"
                        Background="{DynamicResource SurfaceBrush}" MinHeight="200" MaxHeight="480"
                        Visibility="{Binding IsSiteScope, Converter={StaticResource InvBoolToVis}}">
                    <TreeView x:Name="SourceTreeView"
                              ItemsSource="{Binding SourceLibraries}"
                              ItemTemplate="{StaticResource SourceNodeTemplate}"
                              VirtualizingPanel.IsVirtualizing="False"
                              ScrollViewer.CanContentScroll="False"
                              ScrollViewer.VerticalScrollBarVisibility="Visible"
                              Padding="4">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <EventSetter Event="Expanded" Handler="SourceTreeItem_Expanded"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Border>
            </Grid>
            </ScrollViewer>

            <!-- ── Step 2: Target URL + Folder ───────────────────────────── -->
            <!-- Outer scroll: on small windows the destination-folder tree (capped at 480px) plus its
                 headers can exceed the window; without this the bottom of the tree was clipped with no
                 way to reach it. The tree keeps its own internal scroll. -->
            <ScrollViewer Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=2}"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid MaxWidth="1000" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="300"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*" MinWidth="300"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Connect to Target Site" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Style="{StaticResource SubHeader}">
                        Enter the URL of the destination site collection.
                    </TextBlock>

                    <TextBlock Text="Target Site URL" Style="{StaticResource FieldLabel}" Margin="0,22,0,4"/>
                    <TextBox Text="{Binding TargetUrl, UpdateSourceTrigger=PropertyChanged}"
                             Tag="https://contoso.sharepoint.com/sites/target"
                             Style="{StaticResource WatermarkTextBox}"
                             Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Connect to Target" Style="{StaticResource PrimaryBtn}"
                                Command="{Binding ConnectTargetCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                                Visibility="{Binding IsConnectingTarget, Converter={StaticResource InvBoolToVis}}"/>
                        <Button Content="Disconnect" Style="{StaticResource DangerBtn}"
                                Command="{Binding CancelConnectTargetCommand}"
                                Visibility="{Binding IsConnectingTarget, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                Visibility="{Binding TargetStatus, Converter={StaticResource NotNullToVis}}">
                        <TextBlock Text="{Binding TargetStatus}" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text=" · " Foreground="{DynamicResource TextPlaceholderBrush}" FontSize="13" VerticalAlignment="Center"
                                   Visibility="{Binding TargetConnected, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Disconnect" Style="{StaticResource LinkBtn}"
                                Command="{Binding DisconnectTargetCommand}"
                                Foreground="{DynamicResource TextTertiaryBrush}" FontSize="13" Padding="0" VerticalAlignment="Center"
                                Visibility="{Binding TargetConnected, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <ProgressBar IsIndeterminate="True" Height="4" Margin="0,12,0,0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

                    <Border Style="{StaticResource WarningBanner}" Margin="0,20,0,0"
                            Visibility="{Binding NeedsTargetFolder, Converter={StaticResource BoolToVis}}">
                        <TextBlock TextWrapping="Wrap" FontSize="12">
                            Select the destination folder in the tree on the right.
                            Files will be copied into that folder.
                        </TextBlock>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Select Destination Folder" Style="{StaticResource SectionHeader}"
                               Visibility="{Binding NeedsTargetFolder, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="Target Site" Style="{StaticResource SectionHeader}"
                               Visibility="{Binding NeedsTargetFolder, Converter={StaticResource InvBoolToVis}}"/>

                    <!-- Folder picker (Files / Pages scope) -->
                    <StackPanel Visibility="{Binding NeedsTargetFolder, Converter={StaticResource BoolToVis}}">
                        <TextBlock Style="{StaticResource SubHeader}"
                                   Visibility="{Binding IsFilesScope, Converter={StaticResource BoolToVis}}">
                            Click a library or folder to select it as the copy destination.
                        </TextBlock>
                        <TextBlock Style="{StaticResource SubHeader}"
                                   Visibility="{Binding IsPagesScope, Converter={StaticResource BoolToVis}}">
                            The Site Pages library has been automatically selected as the destination.
                            Pages can only be copied into a Site Pages library.
                        </TextBlock>

                        <Border Padding="10,6" Margin="0,0,0,8">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource InfoBanner}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTargetFolder}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Hidden"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="13">
                                <Run FontFamily="{StaticResource GlyphFont}" Text="&#xE8B7;"/>
                                <Run Text=" Selected: "/>
                                <Run Text="{Binding SelectedTargetFolder.Name}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </Border>

                        <Border BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" MinHeight="300" MaxHeight="480">
                            <TreeView x:Name="TargetTreeView"
                                      ItemsSource="{Binding TargetLibraries}"
                                      ItemTemplate="{StaticResource TargetNodeTemplate}"
                                      SelectedItemChanged="TargetTree_SelectedItemChanged"
                                      VirtualizingPanel.IsVirtualizing="False"
                                      ScrollViewer.CanContentScroll="False"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible"
                                      Padding="4">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        <EventSetter Event="Expanded" Handler="TargetTreeItem_Expanded"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>
                        </Border>
                    </StackPanel>

                    <!-- Library / Site scope: no folder picker needed -->
                    <StackPanel Visibility="{Binding NeedsTargetFolder, Converter={StaticResource InvBoolToVis}}">
                        <TextBlock Style="{StaticResource SubHeader}">
                            Libraries and lists will be created at the root of the target site. No folder selection is needed.
                        </TextBlock>
                        <Border Style="{StaticResource InfoBanner}" Padding="14,12" Margin="0,16,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#xE946;" Style="{StaticResource GlyphIcon}"
                                               Foreground="{DynamicResource AccentBrush}" FontSize="13" Margin="0,0,6,0"/>
                                    <TextBlock Text="Library / List Creation" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                                    Libraries and lists will be created at the root of the target site, preserving column schema and versioning settings. If a library or list already exists, any missing source columns will be added to it.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SuccessBanner}" Padding="10,6" Margin="0,12,0,0"
                                Visibility="{Binding TargetConnected, Converter={StaticResource BoolToVis}}">
                            <TextBlock FontSize="12">
                                <Run FontFamily="{StaticResource GlyphFont}" Text="&#xE73E;" Foreground="{DynamicResource SuccessBrush}"/>
                                <Run Text=" Target: " FontWeight="SemiBold"/>
                                <Run Text="{Binding TargetUrl}"/>
                            </TextBlock>
                        </Border>

                        <!-- Destination list picker — only when individual items are selected -->
                        <StackPanel Visibility="{Binding IsItemSelectionActive, Converter={StaticResource BoolToVis}}"
                                    Margin="0,16,0,0">
                            <TextBlock Text="Destination List" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding TargetCustomLists}"
                                      SelectedItem="{Binding SelectedTargetList}"
                                      DisplayMemberPath="Title"
                                      Margin="0,0,0,6"/>
                            <TextBox Style="{StaticResource WatermarkTextBox}"
                                     Tag="Enter the name of the new list to create"
                                     Text="{Binding NewListName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,6"
                                     Visibility="{Binding IsCreatingNewList, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}">
                                Select the list on the target site where the selected items will be copied.
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>
            </ScrollViewer>

            <!-- ── Step 3: Options + Review ───────────────────────────────── -->
            <Grid Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=3}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*" MinWidth="320"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                  <StackPanel>
                    <TextBlock Text="Copy Options" Style="{StaticResource SectionHeader}"/>

                    <!-- ── File options (Files, Library &amp; Site scopes) ────────── -->
                    <Border Style="{StaticResource Card}" Margin="0,8,0,0"
                            Visibility="{Binding IsPagesScope, Converter={StaticResource InvBoolToVis}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="&#xE7C3;" Style="{StaticResource CardHeaderGlyph}"/>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CardHeader}">
                                            <Setter Property="Text" Value="File Options"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLibraryOrSiteScope}" Value="True">
                                                    <Setter Property="Text" Value="Library &amp; File Options"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!-- Library/Site scope: master toggle for copying file content -->
                            <CheckBox IsChecked="{Binding CopyLibraryContent}" Margin="0,0,0,8" FontSize="13"
                                      Visibility="{Binding IsLibraryOrSiteScope, Converter={StaticResource BoolToVis}}"
                                      AutomationProperties.Name="Copy library content (files)">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Copy library content (files)" VerticalAlignment="Center"/>
                                    <TextBlock Style="{StaticResource ToolTipIcon}">
                                        <TextBlock.ToolTip>
                                            <ToolTip MaxWidth="280">
                                                <TextBlock TextWrapping="Wrap" FontSize="12"
                                                           Text="When off, only the column schema and library settings are recreated — no files are copied."/>
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                </StackPanel>
                            </CheckBox>

                            <!-- Shared file copy options (Files scope, or Library/Site with content enabled) -->
                            <StackPanel Visibility="{Binding ShowFileCopyOptions, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="If file exists:" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <RadioButton GroupName="OverwriteMode" FontSize="12" Content="Skip" VerticalAlignment="Center"
                                                 IsChecked="{Binding OverwriteMode, Converter={StaticResource EqToBool}, ConverterParameter=Skip}"/>
                                    <RadioButton GroupName="OverwriteMode" FontSize="12" Content="Overwrite" Margin="10,0,0,0" VerticalAlignment="Center"
                                                 IsChecked="{Binding OverwriteMode, Converter={StaticResource EqToBool}, ConverterParameter=Overwrite}"/>
                                    <RadioButton GroupName="OverwriteMode" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"
                                                 IsChecked="{Binding OverwriteMode, Converter={StaticResource EqToBool}, ConverterParameter=IfNewer}">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="If newer" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Style="{StaticResource ToolTipIcon}">
                                                <TextBlock.ToolTip>
                                                    <ToolTip MaxWidth="280">
                                                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                                                   Text="Incremental re-copy: replaces a file only when the source was modified after the target. Unchanged files are reported as 'Up to date'. When 'Copy permissions' is enabled, permissions still refresh on up-to-date files. Ideal for a final top-up copy at cutover while users kept working in the source."/>
                                                    </ToolTip>
                                                </TextBlock.ToolTip>
                                            </TextBlock>
                                        </StackPanel>
                                    </RadioButton>
                                </StackPanel>
                                <CheckBox IsChecked="{Binding CopyVersions}" Margin="0,0,0,8" FontSize="13"
                                          AutomationProperties.Name="Copy version history">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Copy version history" VerticalAlignment="Center"/>
                                        <TextBlock Style="{StaticResource ToolTipIcon}">
                                            <TextBlock.ToolTip>
                                                <ToolTip MaxWidth="280">
                                                    <TextBlock TextWrapping="Wrap" FontSize="12"
                                                               Text="Copies file version history. Versions are uploaded oldest-first so history builds naturally."/>
                                                </ToolTip>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding CopyVersions, Converter={StaticResource BoolToVis}}"
                                            Margin="24,0,0,8">
                                    <RadioButton GroupName="VersionDepth" Content="All versions"
                                                 IsChecked="{Binding CopyAllVersions}"
                                                 FontSize="12" VerticalAlignment="Center"/>
                                    <RadioButton GroupName="VersionDepth" Margin="14,0,0,0" VerticalAlignment="Center"
                                                 IsChecked="{Binding CopyAllVersions, Converter={StaticResource InvBool}}"
                                                 AutomationProperties.Name="Latest N versions">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Latest " FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                            <TextBox Text="{Binding MaxVersions, UpdateSourceTrigger=PropertyChanged}"
                                                     IsEnabled="{Binding CopyAllVersions, Converter={StaticResource InvBool}}"
                                                     Width="48" FontSize="12" Padding="6,2" VerticalAlignment="Center"/>
                                            <TextBlock Text=" versions" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </RadioButton>
                                </StackPanel>
                                <!-- ── Site-scope only: Navigation ─── -->
                                <CheckBox IsChecked="{Binding CopyNavigation}" Margin="0,0,0,8" FontSize="13"
                                          Visibility="{Binding IsSiteScope, Converter={StaticResource BoolToVis}}"
                                          AutomationProperties.Name="Copy navigation">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Copy navigation (Quick Launch &amp; top bar)" VerticalAlignment="Center"/>
                                        <TextBlock Style="{StaticResource ToolTipIcon}">
                                            <TextBlock.ToolTip>
                                                <ToolTip MaxWidth="280">
                                                    <TextBlock TextWrapping="Wrap" FontSize="12"
                                                               Text="Replaces target navigation with source links. URLs are remapped to the target site."/>
                                                </ToolTip>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                                <!-- ── Permissions ─── -->
                                <CheckBox IsChecked="{Binding CopyPermissions, Mode=TwoWay}" Margin="0,0,0,0" FontSize="13"
                                          AutomationProperties.Name="Copy permissions">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Copy permissions" VerticalAlignment="Center"/>
                                        <TextBlock Style="{StaticResource ToolTipIcon}">
                                            <TextBlock.ToolTip>
                                                <ToolTip MaxWidth="280">
                                                    <TextBlock TextWrapping="Wrap" FontSize="12"
                                                               Text="Copies unique role assignments — for files in Files scope; for libraries, lists, folders, files, and items in Library and Site scopes. Works best for same-tenant copies."/>
                                                </ToolTip>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── Pages-specific options ───────────────────────────────── -->
                    <Border Style="{StaticResource Card}" Margin="0,8,0,0"
                            Visibility="{Binding IsPagesScope, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="&#xE8A1;" Style="{StaticResource CardHeaderGlyph}"/>
                                <TextBlock Text="Page Options" Style="{StaticResource CardHeader}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="If page exists:" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <RadioButton GroupName="PageOverwriteMode" FontSize="12" Content="Skip" VerticalAlignment="Center"
                                             IsChecked="{Binding OverwriteMode, Converter={StaticResource EqToBool}, ConverterParameter=Skip}"/>
                                <RadioButton GroupName="PageOverwriteMode" FontSize="12" Content="Overwrite" Margin="10,0,0,0" VerticalAlignment="Center"
                                             IsChecked="{Binding OverwriteMode, Converter={StaticResource EqToBool}, ConverterParameter=Overwrite}"/>
                                <RadioButton GroupName="PageOverwriteMode" FontSize="12" Content="If newer" Margin="10,0,0,0" VerticalAlignment="Center"
                                             IsChecked="{Binding OverwriteMode, Converter={StaticResource EqToBool}, ConverterParameter=IfNewer}"/>
                            </StackPanel>
                            <CheckBox IsChecked="{Binding RemapPageWebPartUrls}" Margin="0,0,0,0" FontSize="13"
                                      AutomationProperties.Name="Remap web part URLs to target site">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Remap web part URLs to target site" VerticalAlignment="Center"/>
                                    <TextBlock Style="{StaticResource ToolTipIcon}">
                                        <TextBlock.ToolTip>
                                            <ToolTip MaxWidth="280">
                                                <TextBlock TextWrapping="Wrap" FontSize="12"
                                                           Text="Replaces source site URLs in web part JSON. Web parts referencing specific list IDs may still need manual review after copy."/>
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                </StackPanel>
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <!-- ── Advanced options (metadata, custom columns, copy mode, performance) ── -->
                    <Expander Style="{StaticResource OptionsExpander}" Margin="0,8,0,0">
                        <Expander.Header>
                            <TextBlock Text="Advanced options" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextTertiaryBrush}"/>
                        </Expander.Header>
                        <StackPanel>
                            <!-- Metadata: preserved author/dates grouped with custom column values -->
                            <TextBlock Text="Metadata" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>

                            <CheckBox IsChecked="{Binding PreserveMetadata}" Margin="0,0,0,8" FontSize="12"
                                      AutomationProperties.Name="Preserve metadata">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Preserve metadata" VerticalAlignment="Center"/>
                                    <TextBlock Style="{StaticResource ToolTipIcon}">
                                        <TextBlock.ToolTip>
                                            <ToolTip MaxWidth="280">
                                                <TextBlock TextWrapping="Wrap" FontSize="12"
                                                           Text="Preserves Created By, Created Date, Modified By, and Modified Date on every copied item. When off, items appear as created by you today."/>
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                </StackPanel>
                            </CheckBox>

                            <!-- Only meaningful while Preserve metadata is on; disabled otherwise so its
                                 effect is never ambiguous. Off = big speed win on repeated mostly-skipped runs. -->
                            <CheckBox IsChecked="{Binding ReapplyFolderMetadataEveryRun}" Margin="0,0,0,8" FontSize="12"
                                      IsEnabled="{Binding PreserveMetadata}"
                                      AutomationProperties.Name="Re-apply folder metadata on every run">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Re-apply folder metadata every run" VerticalAlignment="Center"/>
                                    <TextBlock Style="{StaticResource ToolTipIcon}">
                                        <TextBlock.ToolTip>
                                            <ToolTip MaxWidth="280">
                                                <TextBlock TextWrapping="Wrap" FontSize="12"
                                                           Text="On: repairs folder Created/Modified dates and authors for every folder in the selection on each run — needed to fix folder metadata on an already-copied target, but adds a per-folder scan that runs even when every file is skipped. Off: only folders that receive new files this run are dated, making repeated 'mostly skipped' runs much faster. Applies only when Preserve metadata is on."/>
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                </StackPanel>
                            </CheckBox>

                            <!-- Files scope: opt-in checkbox + mapping button -->
                            <StackPanel Visibility="{Binding IsFilesScope, Converter={StaticResource BoolToVis}}">
                                <CheckBox IsChecked="{Binding CopyCustomColumns}" Margin="0,0,0,4" FontSize="12"
                                          AutomationProperties.Name="Copy custom column values"
                                          x:Name="CopyCustomColumnsCheckBox" Checked="CopyCustomColumns_Changed" Unchecked="CopyCustomColumns_Changed">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Copy custom column values" VerticalAlignment="Center"/>
                                        <TextBlock Style="{StaticResource ToolTipIcon}">
                                            <TextBlock.ToolTip>
                                                <ToolTip MaxWidth="280">
                                                    <TextBlock TextWrapping="Wrap" FontSize="12"
                                                               Text="Copies Text, Number, Choice, Date, Boolean, Multi-choice, Person, and Managed Metadata column values. Lookup columns are not supported."/>
                                                </ToolTip>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                                <Button Margin="20,8,0,0" HorizontalAlignment="Left"
                                        Style="{StaticResource SecondaryBtn}"
                                        Click="ConfigureMappings_Click"
                                        Content="{Binding MappingButtonLabel}"
                                        IsEnabled="{Binding CanConfigureMappings}"/>
                                <TextBlock Text="Enable 'Copy custom column values' to configure mappings."
                                           Style="{StaticResource OptionCaption}" Margin="20,4,0,0"
                                           Visibility="{Binding CopyCustomColumns, Converter={StaticResource InvBoolToVis}}"/>
                            </StackPanel>

                            <!-- Site scope (full copy): all column values are always transferred -->
                            <TextBlock Visibility="{Binding ShowLibrarySummaryLine, Converter={StaticResource BoolToVis}}"
                                       TextWrapping="Wrap" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}">
                                All custom column values are copied automatically.
                            </TextBlock>

                            <!-- Library / List scope (full copy): mapping button -->
                            <StackPanel Visibility="{Binding ShowLibraryFullCopyMapping, Converter={StaticResource BoolToVis}}"
                                        Margin="0,4,0,0">
                                <TextBlock Text="All custom column values are copied. Use mappings to control which columns are created at the destination."
                                           Style="{StaticResource OptionCaption}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                <Button HorizontalAlignment="Left"
                                        Style="{StaticResource SecondaryBtn}"
                                        Click="ConfigureMappings_Click"
                                        Content="{Binding MappingButtonLabel}"
                                        IsEnabled="{Binding IsColumnsReady}"/>
                            </StackPanel>

                            <!-- Pages scope: column values always copied — just show mapping button -->
                            <StackPanel Visibility="{Binding IsPagesScope, Converter={StaticResource BoolToVis}}"
                                        Margin="0,4,0,0">
                                <TextBlock Text="All custom column values are copied. Use mappings to control which columns are created at the destination."
                                           Style="{StaticResource OptionCaption}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                <Button HorizontalAlignment="Left"
                                        Style="{StaticResource SecondaryBtn}"
                                        Click="ConfigureMappings_Click"
                                        Content="{Binding MappingButtonLabel}"
                                        IsEnabled="{Binding IsColumnsReady}"/>
                            </StackPanel>

                            <!-- Library scope (individual items): column values always copied — just show mapping button -->
                            <StackPanel Visibility="{Binding IsItemSelectionActive, Converter={StaticResource BoolToVis}}"
                                        Margin="0,4,0,0">
                                <TextBlock Text="Custom column values are always copied for list items."
                                           Style="{StaticResource OptionCaption}" Margin="0,0,0,8"/>
                                <Button HorizontalAlignment="Left"
                                        Style="{StaticResource SecondaryBtn}"
                                        Click="ConfigureMappings_Click"
                                        Content="{Binding MappingButtonLabel}"
                                        IsEnabled="{Binding IsColumnsReady}"/>
                            </StackPanel>

                            <!-- Copy mode + performance (not applicable to Pages scope) -->
                            <StackPanel Visibility="{Binding IsPagesScope, Converter={StaticResource InvBoolToVis}}">
                                <Separator Margin="0,10,0,10" Background="{DynamicResource BorderLightBrush}"/>
                                <TextBlock Text="Copy mode" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <RadioButton GroupName="CopyMode" FontSize="12" Margin="0,0,0,6"
                                             IsChecked="{Binding CopyMode, Converter={StaticResource EqToBool}, ConverterParameter=MigrationApi}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Migration API" VerticalAlignment="Center"/>
                                        <Border Background="{DynamicResource AccentBrush}" CornerRadius="3" Padding="4,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="Recommended" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Style="{StaticResource ToolTipIcon}" MouseLeftButtonDown="InfoIcon_Click">
                                            <TextBlock.ToolTip>
                                                <ToolTip>
                                                    <TextBlock Text="Exact version numbers, dates, and editors. Requires Site Collection Admin on the target." TextWrapping="Wrap" MaxWidth="260"/>
                                                </ToolTip>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton GroupName="CopyMode" FontSize="12" Margin="0,0,0,12"
                                             IsChecked="{Binding CopyMode, Converter={StaticResource EqToBool}, ConverterParameter=EnhancedRest}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Enhanced REST" VerticalAlignment="Center"/>
                                        <TextBlock Style="{StaticResource ToolTipIcon}" MouseLeftButtonDown="InfoIcon_Click">
                                            <TextBlock.ToolTip>
                                                <ToolTip>
                                                    <TextBlock Text="Correct dates and editors per version, but version numbers double (2, 4, 6…). No admin rights required." TextWrapping="Wrap" MaxWidth="260"/>
                                                </ToolTip>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                    </StackPanel>
                                </RadioButton>
                                <Separator Margin="0,0,0,10" Background="{DynamicResource BorderLightBrush}"/>
                                <TextBlock Text="Parallel copies" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <Slider Minimum="1" Maximum="16" Value="{Binding MaxParallelCopies}"
                                            Width="120" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding MaxParallelCopies}" FontSize="14" FontWeight="SemiBold"
                                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Higher values copy faster but may throttle on large sites."
                                           Style="{StaticResource OptionCaption}" Margin="0"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander>
                  </StackPanel>
                </ScrollViewer>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header with selection summary, kept next to the preview it describes -->
                    <DockPanel Grid.Row="0" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Text="Copy Preview" Style="{StaticResource SectionHeader}"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Visibility="{Binding IsFilesOrPagesScope, Converter={StaticResource BoolToVis}}">
                                <Run Text="{Binding CopyJobs.Count, Mode=OneWay}" FontWeight="Bold"/>
                                <Run Text="items selected"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Visibility="{Binding ShowLibrarySummaryLine, Converter={StaticResource BoolToVis}}">
                                <Run Text="{Binding LibrarySummaryCount, Mode=OneWay}" FontWeight="Bold"/>
                                <Run Text="libraries &amp; lists to copy"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Visibility="{Binding IsItemSelectionActive, Converter={StaticResource BoolToVis}}">
                                <Run Text="{Binding SelectedItemCount, Mode=OneWay}" FontWeight="Bold"/>
                                <Run Text="list items to copy"/>
                            </TextBlock>
                        </StackPanel>
                    </DockPanel>
                    <StackPanel Grid.Row="1" Margin="0,0,0,8">
                        <Border Style="{StaticResource InfoBanner}" Padding="10,6" Margin="0,0,0,4">
                            <TextBlock FontSize="12" TextWrapping="Wrap">
                                <Run Text="From: " FontWeight="SemiBold"/>
                                <Run Text="{Binding SourceUrl}"/>
                            </TextBlock>
                        </Border>
                        <Border Style="{StaticResource InfoBanner}" Padding="10,6">
                            <TextBlock FontSize="12" TextWrapping="Wrap">
                                <Run Text="To: " FontWeight="SemiBold"/>
                                <Run Text="{Binding TargetUrl}"/>
                            </TextBlock>
                        </Border>
                        <Border Style="{StaticResource SuccessBanner}" Padding="10,6" Margin="0,4,0,0"
                                Visibility="{Binding IsItemSelectionActive, Converter={StaticResource BoolToVis}}">
                            <TextBlock FontSize="12" TextWrapping="Wrap">
                                <Run Text="Destination List: " FontWeight="SemiBold"/>
                                <Run Text="{Binding EffectiveDestinationListName, Mode=OneWay}"/>
                            </TextBlock>
                        </Border>
                        <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" TextWrapping="Wrap"
                                   Visibility="{Binding IsFilesScope, Converter={StaticResource BoolToVis}}">
                            Folders are recursively enumerated during the copy.
                        </TextBlock>
                        <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" TextWrapping="Wrap"
                                   Visibility="{Binding IsLibraryOrSiteScope, Converter={StaticResource BoolToVis}}">
                            Files in each library and items in each list are enumerated at copy time.
                        </TextBlock>
                    </StackPanel>

                    <!-- Library / Site scope: list selected libraries -->
                    <Border Grid.Row="2" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}"
                            Visibility="{Binding IsLibraryOrSiteScope, Converter={StaticResource BoolToVis}}">
                      <Grid>
                        <TextBlock Text="Nothing selected yet — go back to Browse and check the libraries or lists you want to copy."
                                   Style="{StaticResource GhostText}"
                                   Visibility="{Binding LibrarySummaryCount, Converter={StaticResource EqToVis}, ConverterParameter=0}"/>
                        <ListView ItemsSource="{Binding LibraryPreviewItems}" Padding="4" Background="Transparent">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Library / List" Width="220">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding TypeIcon}" Style="{StaticResource GlyphIcon}"
                                                               FontSize="13" Foreground="{DynamicResource AccentBrush}" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Destination Name" Width="200">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <!-- Item-level copies: the destination list was chosen on the Target
                                                     step, so this column is display-only there. Whole library/list
                                                     copies: editable rename. -->
                                                <TextBox Text="{Binding OverrideName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Tag="{Binding Name}"
                                                         FontSize="12" Background="Transparent"
                                                         VerticalAlignment="Center" Width="185">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox" BasedOn="{StaticResource WatermarkTextBox}">
                                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderInputBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.IsItemSelectionActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                    <Setter Property="IsReadOnly" Value="True"/>
                                                                    <Setter Property="IsTabStop" Value="False"/>
                                                                    <Setter Property="Cursor" Value="Arrow"/>
                                                                    <Setter Property="BorderThickness" Value="0"/>
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                                    <Setter Property="ToolTip" Value="The destination list was chosen on the Target step. Go back to change it."/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                      </Grid>
                    </Border>

                    <!-- Files / Pages scope: list selected file jobs -->
                    <Border Grid.Row="2" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}"
                            Visibility="{Binding IsFilesOrPagesScope, Converter={StaticResource BoolToVis}}">
                      <Grid>
                        <TextBlock Text="Nothing selected yet — go back to Browse and check the files or folders you want to copy."
                                   Style="{StaticResource GhostText}"
                                   Visibility="{Binding CopyJobs.Count, Converter={StaticResource EqToVis}, ConverterParameter=0}"/>
                        <ListView ItemsSource="{Binding CopyJobs}" Background="Transparent"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Type" Width="50">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontFamily="{StaticResource GlyphFont}" FontSize="14"
                                                           Foreground="{DynamicResource AccentBrush}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="&#xE7C3;"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                    <Setter Property="Text" Value="&#xE8B7;"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Source Path" Width="360">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SourceDisplayPath}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding SourceDisplayPath}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Destination Path" Width="360">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding TargetDisplayPath}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding TargetDisplayPath}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                      </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- ── Step 4: Copying Progress ───────────────────────────────── -->
            <Grid Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=4}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SectionHeader}">
                                <Setter Property="Text" Value="Copying Files…"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLibraryOrSiteScope}" Value="True">
                                        <Setter Property="Text" Value="Copying Libraries…"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding RunSettingsSummary}" FontSize="11" Margin="0,4,0,0"
                               TextWrapping="Wrap" Foreground="{DynamicResource TextTertiaryBrush}"/>
                </StackPanel>

                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock FontSize="13">
                                <Run Text="{Binding CompletedCount}"/>
                                <Run Text=" of "/>
                                <Run Text="{Binding TotalCount}"/>
                                <Run Text=" items processed"/>
                                <Run Text="{Binding EstimatedTimeRemaining}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                            </TextBlock>
                            <TextBlock HorizontalAlignment="Right" FontSize="13" FontWeight="SemiBold">
                                <Run Text="{Binding TotalProgress, StringFormat={}{0:N0}}"/>
                                <Run Text="%"/>
                                <Run Text="   "/>
                                <Run FontFamily="{StaticResource GlyphFont}" Text="&#xE916;" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                <Run Text=" " Foreground="{DynamicResource TextTertiaryBrush}"/>
                                <Run Text="{Binding ElapsedTime}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                            </TextBlock>
                        </Grid>
                        <ProgressBar Value="{Binding TotalProgress}" Maximum="100" Height="12"
                                     Background="{DynamicResource BorderLightBrush}" Foreground="{DynamicResource AccentBrush}"/>
                        <Button Content="Cancel" Style="{StaticResource DangerBtn}"
                                HorizontalAlignment="Left" Margin="0,12,0,0"
                                Command="{Binding CancelCopyCommand}"
                                Visibility="{Binding IsCancelable, Converter={StaticResource BoolToVis}}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                    Visibility="{Binding IsPreflightInProgress, Converter={StaticResource BoolToVis}}">
                            <ProgressBar IsIndeterminate="True" Width="80" Height="4"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"
                                       VerticalAlignment="Center">
                                <Run Text="Checking files… "/>
                                <Run Text="{Binding PreflightChecked}"/>
                                <Run Text=" of "/>
                                <Run Text="{Binding PreflightTotal}"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                    Visibility="{Binding IsPackingInProgress, Converter={StaticResource BoolToVis}}">
                            <ProgressBar IsIndeterminate="True" Width="80" Height="4"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding PackedCount, StringFormat={}{0:N0}}"/>
                                <Run Text=" / "/>
                                <Run Text="{Binding TotalCount, StringFormat={}{0:N0}}"/>
                                <Run Text=" files packaged for import"/>
                                <Run Text="{Binding PackagedEstimatedTimeRemaining}"/>
                            </TextBlock>
                        </StackPanel>
                        <!-- Live activity feed -->
                        <Border Margin="0,8,0,0" MaxHeight="90"
                                BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="8,6"
                                Visibility="{Binding IsCopying, Converter={StaticResource BoolToVis}}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Activity"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBox Text="{Binding ActivityText, Mode=OneWay}"
                                         FontSize="11" FontFamily="Consolas"
                                         Foreground="{DynamicResource TextSecondaryBrush}"
                                         TextWrapping="Wrap"
                                         IsReadOnly="True"
                                         BorderThickness="0" Background="Transparent"
                                         Padding="0"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled"
                                         FocusVisualStyle="{x:Null}"/>
                            </DockPanel>
                        </Border>
                        <!-- Full activity log saved to disk (selectable path; survives after the run). -->
                        <TextBox Text="{Binding ActivityLogPath, Mode=OneWay}"
                                 Visibility="{Binding ActivityLogPath, Converter={StaticResource NotNullToVis}}"
                                 IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                 FontSize="10" FontFamily="Consolas" Padding="0" Margin="0,4,0,0"
                                 Foreground="{DynamicResource TextTertiaryBrush}" TextWrapping="Wrap"
                                 FocusVisualStyle="{x:Null}"
                                 ToolTip="Full activity log for this run — select and copy this path to open it after the migration"/>
                        <TextBlock Margin="0,8,0,0" FontSize="13" Foreground="{DynamicResource SuccessBrush}"
                                   Visibility="{Binding IsReadyForReport, Converter={StaticResource BoolToVis}}">
                            <Run FontFamily="{StaticResource GlyphFont}" Text="&#xE73E;"/>
                            <Run Text=" Copy complete! Click Next to see the full report."/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                    Visibility="{Binding IsMetadataInProgress, Converter={StaticResource BoolToVis}}">
                            <ProgressBar IsIndeterminate="True" Width="80" Height="4"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock FontSize="13"
                                       Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center">
                                <Run Text="Updating folder metadata…"/>
                                <Run Text="{Binding MetadataFolderCountText, Mode=OneWay}"/>
                                <Run Text="{Binding MetadataEta, Mode=OneWay}"/>
                                <Run Text="  "/>
                                <Run FontFamily="{StaticResource GlyphFont}" Text="&#xE916;"
                                     Foreground="{DynamicResource TextTertiaryBrush}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding MetadataElapsedTime}"/>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Margin="0,4,0,0" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"
                                   Visibility="{Binding IsMetadataComplete, Converter={StaticResource BoolToVis}}">
                            <Run FontFamily="{StaticResource GlyphFont}" Text="&#xE73E;"/>
                            <Run Text=" Metadata updated · took "/>
                            <Run Text="{Binding MetadataElapsedTime}"/>
                        </TextBlock>
                        <TextBlock Margin="0,4,0,0" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"
                                   Visibility="{Binding IsMetadataCancelled, Converter={StaticResource BoolToVis}}">
                            <Run FontFamily="{StaticResource GlyphFont}" Text="&#xE711;"/>
                            <Run Text=" Metadata update cancelled"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2" Margin="0,0,0,6">
                    <TextBlock Text="Copy Log" Style="{StaticResource CardHeader}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <RadioButton Style="{StaticResource FilterChip}" GroupName="LogFilter4" Content="All"
                                     IsChecked="{Binding ResultFilter, Converter={StaticResource EqToBool}, ConverterParameter=All}"
                                     />
                        <RadioButton Style="{StaticResource FilterChip}" GroupName="LogFilter4"
                                     IsChecked="{Binding ResultFilter, Converter={StaticResource EqToBool}, ConverterParameter=Success}">
                            <TextBlock>
                                <Run Text="Success ("/><Run Text="{Binding SuccessCount, Mode=OneWay}"/><Run Text=")"/>
                            </TextBlock>
                        </RadioButton>
                        <RadioButton Style="{StaticResource FilterChip}" GroupName="LogFilter4"
                                     IsChecked="{Binding ResultFilter, Converter={StaticResource EqToBool}, ConverterParameter=Failed}">
                            <TextBlock>
                                <Run Text="Failed ("/><Run Text="{Binding FailedCount, Mode=OneWay}"/><Run Text=")"/>
                            </TextBlock>
                        </RadioButton>
                        <RadioButton Style="{StaticResource FilterChip}" GroupName="LogFilter4" Margin="0"
                                     IsChecked="{Binding ResultFilter, Converter={StaticResource EqToBool}, ConverterParameter=Skipped}">
                            <TextBlock>
                                <Run Text="Skipped ("/><Run Text="{Binding SkippedCount, Mode=OneWay}"/><Run Text=")"/>
                            </TextBlock>
                        </RadioButton>
                    </StackPanel>
                </Grid>
                <Border Grid.Row="3" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}">
                    <ListView x:Name="ProgressList" ItemsSource="{Binding CopyResultsView}"
                              GridViewColumnHeader.Click="ProgressList_ColumnHeaderClick"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Item"     Width="220" DisplayMemberBinding="{Binding FileName}"/>
                                <GridViewColumn Header="Status"   Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StatusDisplay}"
                                                       Foreground="{Binding Status, Converter={StaticResource StatusColor}}"
                                                       FontSize="12"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Source"   Width="260" DisplayMemberBinding="{Binding SourcePath}"/>
                                <GridViewColumn Header="Target"   Width="260" DisplayMemberBinding="{Binding TargetPath}"/>
                                <GridViewColumn Header="Versions" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="12"
                                                       Visibility="{Binding IsLibraryCreation, Converter={StaticResource InvBoolToVis}}">
                                                <Run Text="{Binding VersionsCopied}"/>
                                                <Run Text="/" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                                <Run Text="{Binding VersionsTotal}" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Details"  Width="220">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                     Padding="0" FontSize="12" Cursor="IBeam"
                                                     Text="{Binding ErrorMessage, Mode=OneWay}"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Permissions Status"
                                    Width="{Binding DataContext.PermColumnWidth, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding PermissionStatusDisplay}"
                                                       Foreground="{Binding PermissionStatusColor}"
                                                       FontSize="12"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Permissions Details"
                                    Width="{Binding DataContext.PermDetailsColumnWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                    DisplayMemberBinding="{Binding PermissionDetails}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </Grid>

            <!-- ── Step 5: Report ─────────────────────────────────────────── -->
            <Grid Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=5}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Copy Report" Style="{StaticResource SectionHeader}"/>

                <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12"
                             HorizontalAlignment="Left" MaxWidth="900">
                    <Border Style="{StaticResource SummaryCard}" Background="{DynamicResource SuccessBgBrush}" BorderBrush="{DynamicResource SuccessBrush}">
                        <StackPanel>
                            <TextBlock Text="{Binding SuccessCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Succeeded" Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryCard}" Background="{DynamicResource DangerBgBrush}" BorderBrush="{DynamicResource DangerBrush}">
                        <StackPanel>
                            <TextBlock Text="{Binding FailedCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource DangerBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Failed" Foreground="{DynamicResource DangerBrush}" HorizontalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryCard}" Background="{DynamicResource WarningBgBrush}" BorderBrush="{DynamicResource WarningBrush}">
                        <StackPanel>
                            <TextBlock Text="{Binding SkippedCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource WarningTextBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Skipped" Foreground="{DynamicResource WarningTextBrush}" HorizontalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryCard}" Background="{DynamicResource WindowBgBrush}" BorderBrush="{DynamicResource BorderLightBrush}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="{Binding CopyDuration}" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Duration" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Border>
                    <!-- Only shown when the run was cancelled or the app closed mid-copy — a fully
                         completed run has zero cancelled items, so this stays hidden (and the
                         UniformGrid re-collapses to a clean 4-tile row) the vast majority of the time. -->
                    <Border Style="{StaticResource SummaryCard}" Background="{DynamicResource WindowBgBrush}" BorderBrush="{DynamicResource BorderLightBrush}"
                            Visibility="{Binding CancelledCount, Converter={StaticResource IntToVis}}">
                        <StackPanel>
                            <TextBlock Text="{Binding CancelledCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Cancelled" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,8,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Style="{StaticResource SecondaryBtn}" Command="{Binding ExportFilesReportCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE896;" Style="{StaticResource GlyphIcon}" FontSize="13" Margin="0,0,6,0"/>
                                    <TextBlock Text="Export CSV" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryBtn}" Margin="8,0,0,0"
                                    Command="{Binding ExportVerificationReportCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE896;" Style="{StaticResource GlyphIcon}" FontSize="13" Margin="0,0,6,0"/>
                                    <TextBlock Text="Verify with Excel Report" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource DangerBtn}" Margin="8,0,0,0"
                                    Command="{Binding CancelVerificationCommand}"
                                    Visibility="{Binding IsVerifying, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Cancel"/>
                            </Button>
                            <CheckBox IsChecked="{Binding DeepVerifyOfficeFiles}" Margin="14,0,0,0" FontSize="12"
                                      VerticalAlignment="Center" IsEnabled="{Binding IsVerifying, Converter={StaticResource InvBool}}"
                                      AutomationProperties.Name="Deep verify Office files">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Deep verify Office files" VerticalAlignment="Center"/>
                                    <TextBlock Style="{StaticResource ToolTipIcon}">
                                        <TextBlock.ToolTip>
                                            <ToolTip MaxWidth="280">
                                                <TextBlock TextWrapping="Wrap" FontSize="12"
                                                           Text="Downloads both copies of each mismatched Office file and compares their internal content, ignoring the metadata parts SharePoint rewrites on upload (Document ID, custom properties, etc.). Slower — use when a hash or date difference needs to be proven real or harmless."/>
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                </StackPanel>
                            </CheckBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <RadioButton Style="{StaticResource FilterChip}" GroupName="FileFilter" Content="All"
                                         IsChecked="{Binding FileResultFilter, Converter={StaticResource EqToBool}, ConverterParameter=All}"/>
                            <RadioButton Style="{StaticResource FilterChip}" GroupName="FileFilter"
                                         IsChecked="{Binding FileResultFilter, Converter={StaticResource EqToBool}, ConverterParameter=Success}">
                                <TextBlock>
                                    <Run Text="Success ("/><Run Text="{Binding FileSuccessCount, Mode=OneWay}"/><Run Text=")"/>
                                </TextBlock>
                            </RadioButton>
                            <RadioButton Style="{StaticResource FilterChip}" GroupName="FileFilter"
                                         IsChecked="{Binding FileResultFilter, Converter={StaticResource EqToBool}, ConverterParameter=Failed}">
                                <TextBlock>
                                    <Run Text="Failed ("/><Run Text="{Binding FileFailedCount, Mode=OneWay}"/><Run Text=")"/>
                                </TextBlock>
                            </RadioButton>
                            <RadioButton Style="{StaticResource FilterChip}" GroupName="FileFilter" Margin="0"
                                         IsChecked="{Binding FileResultFilter, Converter={StaticResource EqToBool}, ConverterParameter=Skipped}">
                                <TextBlock>
                                    <Run Text="Skipped ("/><Run Text="{Binding FileSkippedCount, Mode=OneWay}"/><Run Text=")"/>
                                </TextBlock>
                            </RadioButton>
                        </StackPanel>
                    </Grid>

                    <!-- Full-width row below the button bar — wraps rather than truncates, so a
                         long status message (deep-verify progress, throttle notices, file counts) is
                         always fully visible instead of being clipped in a narrow shared column. -->
                    <TextBlock Grid.Row="1" Text="{Binding StatusMessage}"
                               FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               Visibility="{Binding IsVerifying, Converter={StaticResource BoolToVis}}"/>

                    <Border Grid.Row="2" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1">
                        <DataGrid ItemsSource="{Binding FileResultsView}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column" Background="{DynamicResource SurfaceBrush}"
                                  AlternatingRowBackground="{DynamicResource SurfaceAltBrush}"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Item"        Binding="{Binding FileName}"   Width="220"/>
                                <DataGridTemplateColumn Header="Status" Width="110" SortMemberPath="Status">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StatusDisplay}" Margin="4,2"
                                                       Foreground="{Binding Status, Converter={StaticResource StatusColor}}"
                                                       FontWeight="SemiBold" FontSize="12"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Source Path" Binding="{Binding SourcePath}" Width="260"/>
                                <DataGridTextColumn Header="Target Path" Binding="{Binding TargetPath}" Width="260"/>
                                <DataGridTemplateColumn Header="Versions" Width="65" SortMemberPath="VersionsCopied">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding VersionsCopied}" Margin="4,2"
                                                       Visibility="{Binding IsLibraryCreation, Converter={StaticResource InvBoolToVis}}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Details" Width="220" SortMemberPath="ErrorMessage">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                     Padding="2,1" FontSize="12" Cursor="IBeam"
                                                     Text="{Binding ErrorMessage, Mode=OneWay}"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Permissions Status" SortMemberPath="PermissionStatus"
                                    Width="{Binding DataContext.PermColumnWidth, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding PermissionStatusDisplay}" Margin="4,2"
                                                       Foreground="{Binding PermissionStatusColor}"
                                                       FontWeight="SemiBold" FontSize="12"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Permissions Details"
                                    Binding="{Binding PermissionDetails}"
                                    Width="{Binding DataContext.PermDetailsColumnWidth, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Grid>

        </Grid>

        <!-- ══ Navigation Bar ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="{DynamicResource FooterBgBrush}" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="32,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button Content="← Back" Style="{StaticResource SecondaryBtn}"
                            Command="{Binding BackCommand}"
                            AutomationProperties.Name="BackBtn"
                            Visibility="{Binding CurrentStep, Converter={StaticResource NeqToVis}, ConverterParameter=0}"/>
                    <Button Style="{StaticResource SecondaryBtn}"
                            Margin="8,0,0,0"
                            Click="StartNewCopy_Click"
                            Visibility="{Binding CurrentStep, Converter={StaticResource EqToVis}, ConverterParameter=5}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" Style="{StaticResource GlyphIcon}" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="Start New Copy" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Button Style="{StaticResource PrimaryBtn}" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Command="{Binding NextCommand}"
                        AutomationProperties.Name="NextBtn"
                        Visibility="{Binding CurrentStep, Converter={StaticResource NeqToVis}, ConverterParameter=5}">
                    <Button.Content>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Next →"/>
                                    <Style.Triggers>
                                        <!-- Show "Start Copy" on Step 3 only when no copy has run yet -->
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding CurrentStep}" Value="3"/>
                                                <Condition Binding="{Binding IsCopyComplete}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Text" Value="▶ Start Copy"/>
                                        </MultiDataTrigger>
                                        <DataTrigger Binding="{Binding CurrentStep}" Value="4">
                                            <Setter Property="Text" Value="View Report →"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button.Content>
                </Button>

            </Grid>
        </Border>

        <!-- ══ Toast (transient notification) ═══════════════════════════════════ -->
        <Border x:Name="ToastHost" Grid.Row="0" Grid.RowSpan="4"
                Style="{StaticResource ToastBorder}" Visibility="Collapsed">
            <TextBlock x:Name="ToastText" Foreground="White" FontSize="13"/>
        </Border>

    </Grid>
</Window>
