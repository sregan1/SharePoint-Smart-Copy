<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light theme palette. Counterpart: Colors.Dark.xaml — keep keys in sync.
         Swapped at runtime by Services/ThemeManager. -->

    <SolidColorBrush x:Key="AccentBrush"           Color="#0078D4"/>
    <SolidColorBrush x:Key="AccentLightBrush"      Color="#CCE4F7"/>
    <SolidColorBrush x:Key="SuccessBrush"          Color="#107C10"/>
    <SolidColorBrush x:Key="SuccessBgBrush"        Color="#DFF6DD"/>
    <SolidColorBrush x:Key="DangerBrush"           Color="#A4262C"/>
    <SolidColorBrush x:Key="DangerBgBrush"         Color="#FDE7E9"/>
    <SolidColorBrush x:Key="WarningBrush"          Color="#F7B900"/>
    <SolidColorBrush x:Key="WarningBgBrush"        Color="#FFF4CE"/>
    <SolidColorBrush x:Key="WarningTextBrush"      Color="#7A5900"/>
    <SolidColorBrush x:Key="InfoBgBrush"           Color="#EFF6FC"/>
    <SolidColorBrush x:Key="BorderLightBrush"      Color="#EDEBE9"/>
    <SolidColorBrush x:Key="BorderInputBrush"      Color="#8A8886"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"      Color="#1F1F1F"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"    Color="#323130"/>
    <SolidColorBrush x:Key="TextTertiaryBrush"     Color="#797775"/>
    <SolidColorBrush x:Key="TextPlaceholderBrush"  Color="#A19F9D"/>
    <SolidColorBrush x:Key="WindowBgBrush"         Color="#F3F3F3"/>
    <SolidColorBrush x:Key="SurfaceBrush"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceAltBrush"       Color="#FAFAFA"/>
    <SolidColorBrush x:Key="PermissionRowBrush"    Color="#EEF2FF"/>
    <SolidColorBrush x:Key="UnmatchedBgBrush"      Color="#FFF9F0"/>
    <SolidColorBrush x:Key="TileSelectedTextBrush" Color="#CCE4F7"/>
</ResourceDictionary>
